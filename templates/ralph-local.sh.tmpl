#!/bin/bash
# Ralph local AFK loop — bootstrapped by /setup
#
# Usage:
#   ./templates/ralph-local.sh <issue-number> [max-iterations]
#
# Reads the GitHub issue, runs /tdd + /run-acceptance until every
# @release scenario passes or the budget is exhausted. Before opening
# the draft PR it invokes the reviewer agent and embeds its report.
#
# Implementa: §63 (label gate), §65 (max-iterations), §66 (reviewer
#             pre-PR + retry on blocking), §67 (draft PR),
#             §66 (ralph-blocked label + structured comment via
#                  block_issue + comment template),
#             §69 (NDJSON session log via ralph-lib.sh),
#             §70 (exponential backoff on HTTP 429 via
#                  call_claude_with_retry).
# Status: production-ready (per docs/specs/ralph-hardening.md).

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────
# Bootstrap: locate and source ralph-lib.sh
# ──────────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RALPH_LIB="${SCRIPT_DIR}/ralph-lib.sh"
BLOCKED_COMMENT_TEMPLATE="${SCRIPT_DIR}/ralph-blocked-comment.md.tmpl"

if [ ! -f "$RALPH_LIB" ]; then
  echo "❌ ralph-lib.sh not found in ${SCRIPT_DIR}" >&2
  echo "   Expected: $RALPH_LIB" >&2
  exit 1
fi

if [ ! -f "$BLOCKED_COMMENT_TEMPLATE" ]; then
  echo "❌ ralph-blocked-comment.md.tmpl not found in ${SCRIPT_DIR}" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$RALPH_LIB"

# Reviewer output captured for the "current attempt" — used to enrich
# the ralph-blocked comment when reviewer findings drive the block.
LAST_REVIEWER_OUTPUT=""
LAST_REVIEWER_SEVERITY=""
# FOLLOW-UP 34: the previous iteration's failure_reason — an actionable
# diagnosis the gate already produced — feeds the NEXT /tdd prompt instead
# of forcing the session to re-discover the failure from scratch (or miss
# it). Cleared after a green iteration.
LAST_FAIL_REASON=""

# ──────────────────────────────────────────────────────────────────────
# Argument parsing
#   ./ralph-local.sh <issue> [max-iter]            positional (back-compat)
#   ./ralph-local.sh <issue> --max-iterations N    override the iteration cap
#   ./ralph-local.sh <issue> --worker-id ID        label this worker (parallel runs)
#   ./ralph-local.sh                               QUEUE MODE — work the whole
#                                                  open `ralph-ready` backlog
# The flags match what README + §63/§107 already document; previously the script
# only accepted positionals, so `--max-iterations`/`--worker-id` were silently
# mis-parsed as the issue number.
# ──────────────────────────────────────────────────────────────────────
ISSUE_NUM=""
MAX_ITER=""
WORKER_ID="${RALPH_WORKER_ID:-w0}"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --max-iterations) MAX_ITER="${2:?--max-iterations requires a value}"; shift 2 ;;
    --max-iterations=*) MAX_ITER="${1#*=}"; shift ;;
    --worker-id) WORKER_ID="${2:?--worker-id requires a value}"; shift 2 ;;
    --worker-id=*) WORKER_ID="${1#*=}"; shift ;;
    --) shift; break ;;
    -*) echo "❌ unknown flag: $1" >&2; exit 2 ;;
    *)
      if [ -z "$ISSUE_NUM" ]; then ISSUE_NUM="$1"
      elif [ -z "$MAX_ITER" ]; then MAX_ITER="$1"
      else echo "❌ unexpected argument: $1" >&2; exit 2; fi
      shift ;;
  esac
done
MAX_ITER="${MAX_ITER:-30}"
export RALPH_WORKER_ID="$WORKER_ID"
BRANCH_PREFIX="agent/feature"

# Queue mode (§63/§107): no issue → process every OPEN `ralph-ready` issue in turn.
# Each issue is run via a self-invocation, so the per-issue path is byte-identical
# to a single-issue run; a blocked issue (exit≠0) does not stop the queue. This is
# what makes the Night Shift "run it and walk away" against the whole backlog.
if [ -z "$ISSUE_NUM" ]; then
  READY=$(gh issue list --label ralph-ready --state open --json number --jq '.[].number' 2>/dev/null || true)
  if [ -z "$READY" ]; then
    echo "✅ No open 'ralph-ready' issues. Nothing to do."
    exit 0
  fi
  echo "🤖 Queue mode (worker ${WORKER_ID}): $(echo "$READY" | tr '\n' ' ')"
  # ⚠️ Order caveat: issues are processed in `gh issue list` order (created DESC),
  # NOT slice-dependency order. If a dependent slice runs before its foundation
  # lands, its gate/acceptance blocks → wasted iterations. Until dependency-aware
  # ordering ships (the DAG already exists via group-slice-issues.mjs /
  # parse-layers-affected.mjs), queue mode ASSUMES order-tolerant / independent
  # slices — queue a dependent backlog and you may wake up to ralph-blocked issues.
  echo "⚠️  Queue mode processes in gh default order (not dependency order) — it assumes independent/order-tolerant slices. For a foundation→dependents backlog, run the foundation issue(s) first by number." >&2
  queue_rc=0
  for n in $READY; do
    echo ""; echo "════════ Issue #$n ════════"
    "$0" "$n" --max-iterations "$MAX_ITER" --worker-id "$WORKER_ID" || queue_rc=$?
  done
  exit "$queue_rc"
fi

# ──────────────────────────────────────────────────────────────────────
# §63 label-contract validation (must run BEFORE init_session so we
# never leave an empty log file for issues we refuse to process).
# One combined fetch: labels (the contract) + title (slug + PR title,
# FOLLOW-UP 36) — the engine used to hit the API twice for one issue.
# ──────────────────────────────────────────────────────────────────────
ISSUE_JSON=$(gh issue view "$ISSUE_NUM" --json labels,title 2>/dev/null || true)
LABELS=$(printf '%s' "$ISSUE_JSON" | jq -r '.labels[].name' 2>/dev/null || true)
ISSUE_TITLE=$(printf '%s' "$ISSUE_JSON" | jq -r '.title // empty' 2>/dev/null || true)

if [ -z "$LABELS" ]; then
  echo "❌ Issue #$ISSUE_NUM does not exist or gh CLI is not authenticated" >&2
  exit 1
fi

if ! ralph_has_label "$LABELS" "ralph-ready"; then
  echo "❌ Issue #$ISSUE_NUM is missing label 'ralph-ready' (§63)" >&2
  exit 1
fi

if ! echo "$LABELS" | grep -qE "^scenarios:"; then
  echo "❌ Issue #$ISSUE_NUM is missing label 'scenarios:scn-*' (§63 mandatory)" >&2
  exit 1
fi

if ! echo "$LABELS" | grep -qE "^budget:"; then
  echo "❌ Issue #$ISSUE_NUM is missing label 'budget:NNk' (§63 mandatory)" >&2
  exit 1
fi

# Extract labeled metadata
SCENARIOS=$(ralph_read_label_value "$LABELS" "scenarios:")
BUDGET=$(ralph_read_label_value "$LABELS" "budget:")
BUDGET_TOKENS=$(ralph_parse_budget_label "$BUDGET")

# FOLLOW-UP 35: an unsupported label grammar (live near-miss: a range form
# scn-031..038) expands to ZERO scenarios with no error — downstream that is
# catastrophic-but-quiet (empty Step-3 selection, blind summaries). Fail
# loudly BEFORE iteration 1, same class as the env pre-flight.
if [ -n "$SCENARIOS" ] && [ -z "$(ralph_expand_scns "$SCENARIOS")" ]; then
  echo "❌ Issue #$ISSUE_NUM has an unparseable scenarios label '${SCENARIOS}' — canonical form is scenarios:scn-NNN+NNN (see /to-issues Step 6). Fix the label and relaunch." >&2
  exit 1
fi

# ──────────────────────────────────────────────────────────────────────
# Initialize session log (§69) — from here on, every action is recorded
# ──────────────────────────────────────────────────────────────────────
ralph_init_session "$ISSUE_NUM"

ralph_log_event "info" "ralph.contract.validated" \
  "{\"scenarios\":$(ralph_json_string "$SCENARIOS"),\"budget\":$(ralph_json_string "$BUDGET"),\"budget_tokens\":${BUDGET_TOKENS},\"max_iterations\":${MAX_ITER}}"

# ──────────────────────────────────────────────────────────────────────
# Environment pre-flight — fail fast BEFORE iteration 1. An environment
# failure (Docker daemon down, placeholder secrets) fails every iteration
# identically and no code edit can fix it. This is an OPERATOR problem,
# not an issue problem: exit without labeling ralph-blocked so the issue
# stays ralph-ready for the relaunch.
# ──────────────────────────────────────────────────────────────────────
if ! PREFLIGHT_MSG=$(ralph_env_preflight); then
  echo "$PREFLIGHT_MSG" >&2
  ralph_log_event "error" "ralph.preflight.failed" \
    "{\"reason\":$(ralph_json_string "$PREFLIGHT_MSG")}"
  ralph_end_session "blocked" "env-preflight-failed"
  exit 1
fi

# ──────────────────────────────────────────────────────────────────────
# Helper: after each successful claude call, check if we've exceeded
# the issue's budget. If yes, block the issue and exit cleanly.
# ──────────────────────────────────────────────────────────────────────
check_budget_or_block() {
  local context_label="${1:-unknown}"
  if ! ralph_check_budget "$BUDGET_TOKENS"; then
    echo "💸 Budget exceeded after ${context_label}: ${RALPH_TOKENS_CUMULATIVE} > ${BUDGET_TOKENS} tokens."
    ralph_log_event "error" "ralph.budget.exceeded" \
      "{\"cumulative\":${RALPH_TOKENS_CUMULATIVE},\"budget\":${BUDGET_TOKENS},\"at_call\":$(ralph_json_string "$context_label")}"
    REVIEWER_SECTION="${LAST_REVIEWER_OUTPUT:+$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "$LAST_REVIEWER_SEVERITY")}"
    REVIEWER_SECTION="${REVIEWER_SECTION:-_Reviewer not invoked before budget exhaustion._}"
    ralph_block_issue "$ISSUE_NUM" \
      "budget-exceeded-during-${context_label}" \
      "$BRANCH" \
      "$RALPH_SESSION_LOG" \
      "$SCENARIOS" \
      "$REVIEWER_SECTION" \
      "$BLOCKED_COMMENT_TEMPLATE"
    ralph_end_session "budget_exceeded" "${context_label}"
    exit 1
  fi
}

# ──────────────────────────────────────────────────────────────────────
# Branch setup
# ──────────────────────────────────────────────────────────────────────
# Sanitize the issue title into a [a-z0-9-]-only slug: non-ASCII (em-dash,
# accents, emoji) passed straight through before and landed in the git ref
# (e.g. a literal U+2014 in the branch name), breaking naive tooling and the
# documented agent/feature-<slug>-<NNN> greppability. tr -c converts every
# non-safe byte (incl. the newline) to '-', -s collapses runs, and the final
# sed strips edge dashes AFTER head so truncation can't leave a trailing '-'.
# NB: iconv exits non-zero on untransliterable bytes (e.g. emoji on BSD
# iconv) while still emitting the transliterated prefix — '|| true' keeps
# pipefail from killing the script and the partial output is exactly what
# we want (the bad byte just disappears instead of becoming a dash).
SLUG=$(printf '%s' "$ISSUE_TITLE" \
  | tr '[:upper:]' '[:lower:]' \
  | { iconv -f utf-8 -t ascii//TRANSLIT 2>/dev/null || true; } \
  | tr -c 'a-z0-9' '-' | tr -s '-' | head -c 40 | sed 's/^-//; s/-$//')
# iconv missing/failing yields an empty slug — never an empty ref segment.
[ -n "$SLUG" ] || SLUG="issue"
BRANCH="${BRANCH_PREFIX}-${SLUG}-${ISSUE_NUM}"

if git checkout -b "$BRANCH" 2>/dev/null; then
  ralph_git_action "checkout-new" "success" "git checkout -b $BRANCH"
else
  git checkout "$BRANCH"
  ralph_git_action "checkout-existing" "success" "git checkout $BRANCH"
fi

echo "🤖 Ralph starting loop for issue #$ISSUE_NUM on branch $BRANCH"
echo "   Session log: $RALPH_SESSION_LOG"
echo "   Scenarios: $SCENARIOS"
echo "   Budget: $BUDGET, Max iterations: $MAX_ITER"

# ──────────────────────────────────────────────────────────────────────
# Main loop
# ──────────────────────────────────────────────────────────────────────
# Structured acceptance result channel (§66): /run-acceptance MUST write
# this file as its last step; the loop reads it with jq. Grepping the
# session's prose for "exit code: 0" is forbidden — phrasing drift read
# green runs as failures for 8 straight iterations on the first live
# consumer run. Per-issue filename so parallel workers don't race.
ACCEPT_RESULT_FILE=".planning/acceptance/issue-${ISSUE_NUM}-result.json"
# FOLLOW-UP 33: the acceptance session ALSO writes the full reviewer report
# here (its Step 8 runs the §114 reviewer — "the single reviewer invocation
# for the slice"); the loop consumes severity from the result file's
# gates.reviewer and the report from this file, and never invokes
# /code-review itself (measured: ~15k tokens of pure duplication per green
# iteration when it did).
REVIEWER_REPORT_FILE=".planning/acceptance/issue-${ISSUE_NUM}-reviewer.md"
mkdir -p .planning/acceptance

for i in $(seq 1 "$MAX_ITER"); do
  echo ""
  echo "=== Iteration $i of $MAX_ITER ==="

  ralph_iteration_start "tdd"
  ITER_EPOCH=$(date +%s)   # staleness floor for this iteration's result file

  # NOTE the `|| RC=$?` idiom: under `set -e`, a bare VAR=$(cmd) with a
  # non-zero cmd kills the whole script BEFORE the rc check — the 124
  # rate-limit paths below were unreachable and a CLI failure took the
  # loop down without marking the issue ralph-blocked.
  # The session's prose is intentionally DISCARDED (>/dev/null): since the
  # structured result channel, nothing parses it — only the result file and
  # the NDJSON events are signals. stderr stays on the console for live
  # diagnosis. (Capturing into never-read variables implied the prose
  # mattered — it does not.)
  TDD_RC=0
  # FU-34: hand the gate's own diagnosis to the implementer (truncated —
  # it is a pointer, not a transcript; the full trail is in the NDJSON).
  FAIL_FEEDBACK=""
  if [ -n "$LAST_FAIL_REASON" ]; then
    FAIL_FEEDBACK=" PREVIOUS ITERATION failed acceptance with: ${LAST_FAIL_REASON:0:600}. Address this FIRST, then continue."
  fi
  CALL_START=$(date +%s); CALL_TOKENS_BEFORE=$RALPH_TOKENS_CUMULATIVE
  ralph_call_claude_with_retry "/tdd for issue #$ISSUE_NUM. Read the FULL issue — body AND comments ('gh issue view $ISSUE_NUM' plus 'gh issue view $ISSUE_NUM --comments'; the plan and its amendments may live in comments). If the latest comment carries reviewer findings, fix those FIRST. Then the scn-* scenarios mentioned ($SCENARIOS) — advance one slice.${FAIL_FEEDBACK}" >/dev/null || TDD_RC=$?
  ralph_call_completed "tdd" "$CALL_START" "$CALL_TOKENS_BEFORE"
  if [ "$TDD_RC" -ne 0 ]; then
    if [ "$TDD_RC" -eq 124 ]; then
      # Rate-limit exhausted — block the issue and bail out.
      ralph_error_tool "claude" "/tdd hit rate-limit exhaustion"
      ralph_iteration_end "rate-limit-exhausted"
      REVIEWER_SECTION="_Not invoked: API rate-limit exhausted during /tdd._"
      ralph_block_issue "$ISSUE_NUM" \
        "rate-limit-exhausted-during-tdd" \
        "$BRANCH" \
        "$RALPH_SESSION_LOG" \
        "$SCENARIOS" \
        "$REVIEWER_SECTION" \
        "$BLOCKED_COMMENT_TEMPLATE"
      ralph_end_session "rate_limit_exhausted" "tdd-call"
      exit 1
    fi
    ralph_error_tool "claude" "/tdd returned non-zero (code $TDD_RC) in iteration $i"
    ralph_iteration_end "tdd-failed"
    continue
  fi

  check_budget_or_block "tdd"

  ACCEPTANCE_RC=0
  # FOLLOW-UP 28: delete the previous result BEFORE the acceptance session.
  # A live retry session decided "nothing changed since the last green run"
  # and skipped the mandatory rewrite — the (correct) staleness check then
  # burned the iteration on result-file-stale. With the pre-delete, a
  # session that skips the write produces result-file-missing: an
  # unambiguous contract violation, never confusable with staleness.
  rm -f "$ACCEPT_RESULT_FILE" "$REVIEWER_REPORT_FILE"
  CALL_START=$(date +%s); CALL_TOKENS_BEFORE=$RALPH_TOKENS_CUMULATIVE
  ralph_call_claude_with_retry "/run-acceptance for the scn-* of issue #$ISSUE_NUM ($SCENARIOS). MANDATORY contract (skills/run-acceptance, final step): write the machine-readable result to ${ACCEPT_RESULT_FILE} with issue, exit_code, scenarios{}, ran, expected, gates{} (including gates.reviewer = your Step-8 reviewer severity), failure_reason — AND the full reviewer report to ${REVIEWER_REPORT_FILE}. ALWAYS rewrite both files fresh in THIS run — even if nothing changed since a previous green run. Do NOT run a separate code review afterwards: your Step-8 reviewer is the single invocation for this slice." >/dev/null || ACCEPTANCE_RC=$?
  ralph_call_completed "run-acceptance" "$CALL_START" "$CALL_TOKENS_BEFORE"
  if [ "$ACCEPTANCE_RC" -eq 124 ]; then
    ralph_error_tool "claude" "/run-acceptance hit rate-limit exhaustion"
    ralph_iteration_end "rate-limit-exhausted"
    REVIEWER_SECTION="_Not invoked: API rate-limit exhausted during /run-acceptance._"
    ralph_block_issue "$ISSUE_NUM" \
      "rate-limit-exhausted-during-acceptance" \
      "$BRANCH" \
      "$RALPH_SESSION_LOG" \
      "$SCENARIOS" \
      "$REVIEWER_SECTION" \
      "$BLOCKED_COMMENT_TEMPLATE"
    ralph_end_session "rate_limit_exhausted" "run-acceptance-call"
    exit 1
  fi

  check_budget_or_block "run-acceptance"

  # Green signal = the structured result file, validated by jq (§66):
  # exists + valid JSON + fresh (this iteration) + right issue +
  # ran >= expected + exit_code == 0. Never the session's prose.
  if ACCEPT_STATUS=$(ralph_acceptance_result_check "$ACCEPT_RESULT_FILE" "$ISSUE_NUM" "$ITER_EPOCH"); then
    ralph_iteration_end "green"
    LAST_FAIL_REASON=""   # FU-34: the diagnosis was consumed; don't leak it forward

    # Per-scenario truth from the result file's scenarios{} map
    # (NOT blanket-passing every labeled scenario).
    ralph_log_scenarios_from_result "$ACCEPT_RESULT_FILE" "$SCENARIOS"

    # ──────────────────────────────────────────────────────────────
    # §66 — Reviewer verdict BEFORE opening PR (FOLLOW-UP 33).
    # The §114 reviewer already ran ONCE inside /run-acceptance (its
    # Step 8: "the single reviewer invocation for the slice"); the
    # session wrote the severity to gates.reviewer and the full report
    # to $REVIEWER_REPORT_FILE. The loop READS both — re-invoking
    # /code-review here duplicated ~15k tokens per green iteration and
    # was the last prose-parsing surface.
    # Retry policy (unchanged):
    #   blocking  → one extra /tdd iteration (counts toward MAX_ITER)
    #   should-fix → embed report, open PR, human decides
    #   suggestion → embed report, open PR
    #   clean      → open PR with brief reviewer-ok note
    # ──────────────────────────────────────────────────────────────
    REVIEWER_SEVERITY=$(jq -r '.gates.reviewer // empty' "$ACCEPT_RESULT_FILE" 2>/dev/null)
    if [ -n "$REVIEWER_SEVERITY" ]; then
      REVIEWER_OUTPUT=$(cat "$REVIEWER_REPORT_FILE" 2>/dev/null \
        || echo "_reviewer report file missing (${REVIEWER_REPORT_FILE}); severity from result file: ${REVIEWER_SEVERITY}_")
      ralph_log_event "info" "ralph.reviewer.findings" \
        "{\"severity\":$(ralph_json_string "$REVIEWER_SEVERITY"),\"source\":\"result-file\"}"
    else
      # Legacy fallback: the result file predates the gates.reviewer
      # contract — invoke the reviewer ONCE here (new-contract sessions
      # never reach this branch).
      echo "🧐 Result file carries no reviewer verdict — fallback /code-review invocation…"
      ralph_log_event "warn" "ralph.reviewer.fallback_invocation" "{\"iteration\":${i}}"
      CALL_START=$(date +%s); CALL_TOKENS_BEFORE=$RALPH_TOKENS_CUMULATIVE
      REVIEWER_OUTPUT=$(ralph_call_claude_with_retry "/code-review on the current diff. Cite the §N rules violated. Mark each finding with 🛑 / ⚠️ / 💡 by severity. MANDATORY: end your report with the literal line 'VERDICT: CLEAN' or 'VERDICT: SUGGESTION' or 'VERDICT: SHOULD-FIX' or 'VERDICT: BLOCKING' — automation parses that exact line." 2>&1 || true)
      ralph_call_completed "code-review" "$CALL_START" "$CALL_TOKENS_BEFORE"
      check_budget_or_block "code-review"
      REVIEWER_SEVERITY=$(ralph_reviewer_severity "$REVIEWER_OUTPUT")
      ralph_log_event "info" "ralph.reviewer.findings" \
        "{\"severity\":$(ralph_json_string "$REVIEWER_SEVERITY"),\"source\":\"fallback-invocation\"}"
    fi
    LAST_REVIEWER_OUTPUT="$REVIEWER_OUTPUT"
    LAST_REVIEWER_SEVERITY="$REVIEWER_SEVERITY"

    if [ "$REVIEWER_SEVERITY" = "blocking" ] && [ "$i" -lt "$MAX_ITER" ]; then
      echo "🛑 Reviewer reported blocking findings. Attempting one extra /tdd iteration to fix…"
      # FOLLOW-UP 26: persist the findings to the channel the implementer
      # READS (FU-17's contract: issue body + comments). Without this the
      # retry /tdd re-ran the standard prompt with NO way to know what to
      # fix (the findings lived only in this shell's memory): the live
      # retry committed nothing, and the findings were unrecoverable after
      # the session died. The comment fixes both — the retry sees them,
      # and they survive any crash for the morning review.
      RETRY_COMMENT=$(printf '## Reviewer findings (iteration %s) — fix these; the acceptance gate re-runs next iteration\n\n%s' \
        "$i" "$(ralph_format_reviewer_section "$REVIEWER_OUTPUT" "$REVIEWER_SEVERITY")")
      if ! gh issue comment "$ISSUE_NUM" --body "$RETRY_COMMENT" >/dev/null 2>&1; then
        ralph_error_tool "gh" "failed to post reviewer findings comment before retry"
      fi
      ralph_log_event "warn" "ralph.reviewer.retry" \
        "{\"reason\":\"blocking-findings\",\"retry_iteration\":$((i+1)),\"findings_posted\":true}"
      # Loop back to the top of the for-loop body for one more iteration.
      # The retry counts toward MAX_ITER because the for-loop increment is implicit.
      continue
    fi

    if [ "$REVIEWER_SEVERITY" = "blocking" ]; then
      # Out of budget for retries — apply ralph-blocked with reviewer context.
      echo "🛑 Reviewer findings still blocking and budget exhausted. Blocking issue."
      ralph_log_event "error" "ralph.reviewer.blocked_no_retry_budget" \
        "{\"iterations_used\":${i},\"max_iterations\":${MAX_ITER}}"
      REVIEWER_SECTION=$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "$LAST_REVIEWER_SEVERITY")
      ralph_block_issue "$ISSUE_NUM" \
        "reviewer-blocking-after-retry-budget-exhausted" \
        "$BRANCH" \
        "$RALPH_SESSION_LOG" \
        "$SCENARIOS" \
        "$REVIEWER_SECTION" \
        "$BLOCKED_COMMENT_TEMPLATE"
      ralph_end_session "blocked" "reviewer-blocking-no-retry-budget"
      exit 1
    fi

    echo "✅ Reviewer severity: ${REVIEWER_SEVERITY}. Creating PR…"

    REVIEWER_SECTION=$(ralph_format_reviewer_section "$REVIEWER_OUTPUT" "$REVIEWER_SEVERITY")

    # FOLLOW-UP 36: review-grade PR, composed from data the engine already
    # holds — both live PRs were manually retitled/re-bodied by the Day
    # Shift before this. Title = the issue's own title; body = per-scenario
    # outcomes (from the result file via summarize), counts, tokens,
    # reviewer verdict + report. Consumers can tune the heredoc.
    PR_TITLE=$(printf '%.110s' "${ISSUE_TITLE:-fix issue} (#${ISSUE_NUM})")
    RAN_EXPECTED=$(jq -r '"\(.ran // "?")/\(.expected // "?")"' "$ACCEPT_RESULT_FILE" 2>/dev/null || echo "?/?")
    SCENARIO_TABLE=$(ralph_summarize_scenarios "$RALPH_SESSION_LOG" "$SCENARIOS")

    PR_BODY=$(cat <<EOF
Automated by Ralph. Closes #$ISSUE_NUM

**Iterations consumed:** $i / $MAX_ITER
**Scenarios (ran/expected):** $RAN_EXPECTED
$SCENARIO_TABLE

**Tokens consumed:** ${RALPH_TOKENS_CUMULATIVE} / ${BUDGET_TOKENS}
**Reviewer severity:** ${REVIEWER_SEVERITY}
**Session log:** \`$RALPH_SESSION_LOG\`

---

$REVIEWER_SECTION

---

> ⚠️ This PR is in draft state per §67. Merge requires human approval.
EOF
)

    # Push BEFORE creating the PR: non-interactive `gh pr create` aborts on
    # an unpushed branch ("you must first push the current branch…"). This
    # is the first instruction every successful run reaches — and it had
    # never executed until the issue-15 run, where it failed at the finish
    # line. --head makes the call worktree/detached-HEAD-proof.
    if ! git push -u origin "$BRANCH"; then
      ralph_git_action "push" "failed" "git push -u origin $BRANCH"
      ralph_error_tool "git" "git push failed before PR creation"
      REVIEWER_SECTION=$(ralph_format_reviewer_section "$REVIEWER_OUTPUT" "$REVIEWER_SEVERITY")
      ralph_block_issue "$ISSUE_NUM" \
        "git-push-failed" \
        "$BRANCH" \
        "$RALPH_SESSION_LOG" \
        "$SCENARIOS" \
        "$REVIEWER_SECTION" \
        "$BLOCKED_COMMENT_TEMPLATE"
      ralph_end_session "blocked" "git-push-failed"
      exit 1
    fi
    ralph_git_action "push" "success" "git push -u origin $BRANCH"

    if gh pr create --draft --head "$BRANCH" --title "$PR_TITLE" --body "$PR_BODY"; then
      ralph_git_action "pr-create" "success" "gh pr create --draft"
      gh issue edit "$ISSUE_NUM" --add-label ralph-done --remove-label ralph-ready >/dev/null 2>&1 || true
      ralph_log_event "info" "ralph.pr.opened" \
        "{\"severity\":$(ralph_json_string "$REVIEWER_SEVERITY")}"
      ralph_end_session "completed"
      exit 0
    else
      ralph_git_action "pr-create" "failed" "gh pr create --draft"
      ralph_error_tool "gh" "gh pr create returned non-zero"
      ralph_end_session "blocked" "gh-pr-create-failed"
      exit 1
    fi
  fi

  # Not green — ACCEPT_STATUS carries the machine-greppable reason
  # (result-file-missing / -stale / exit_code=N: <failure_reason> / …),
  # so a failing run is diagnosable from the NDJSON alone. Per-scenario
  # events are fed only when the file is fresh and for THIS issue (a
  # stale or foreign file must not pollute the scenario summary).
  case "$ACCEPT_STATUS" in
    exit_code=*|ran-below-expected*)
      ralph_log_scenarios_from_result "$ACCEPT_RESULT_FILE" "$SCENARIOS"
      # FOLLOW-UP 33: per the skill, a BLOCKING reviewer verdict makes the
      # acceptance exit non-zero — so blocking normally arrives HERE, not
      # on the green path. Surface the full report through FU-26's channel
      # (issue comment) so the next iteration's /tdd sees what to fix.
      FAIL_REVIEWER=$(jq -r '.gates.reviewer // empty' "$ACCEPT_RESULT_FILE" 2>/dev/null)
      if [ "$FAIL_REVIEWER" = "blocking" ] && [ -f "$REVIEWER_REPORT_FILE" ]; then
        LAST_REVIEWER_OUTPUT=$(cat "$REVIEWER_REPORT_FILE")
        LAST_REVIEWER_SEVERITY="blocking"
        BLOCKING_COMMENT=$(printf '## Reviewer findings (iteration %s) — fix these; the acceptance gate re-runs next iteration\n\n%s' \
          "$i" "$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "blocking")")
        if ! gh issue comment "$ISSUE_NUM" --body "$BLOCKING_COMMENT" >/dev/null 2>&1; then
          ralph_error_tool "gh" "failed to post reviewer findings comment on failing iteration"
        fi
        ralph_log_event "info" "ralph.reviewer.findings" \
          "{\"severity\":\"blocking\",\"source\":\"result-file\",\"posted_to_issue\":true}"
      fi ;;
  esac
  LAST_FAIL_REASON="$ACCEPT_STATUS"   # FU-34: feeds the next /tdd prompt
  ralph_iteration_end "acceptance-failing" "$ACCEPT_STATUS"
  echo "⚠️  Iteration $i did not reach green (${ACCEPT_STATUS}). Tokens: ${RALPH_TOKENS_CUMULATIVE}/${BUDGET_TOKENS}. Continuing…"
  ralph_budget_checkpoint "$RALPH_TOKENS_CUMULATIVE" "$BUDGET_TOKENS"
done

echo "❌ Ralph exhausted $MAX_ITER iterations without green. Marking issue as ralph-blocked."

# Use the reviewer section from the last attempt if any, otherwise a placeholder.
if [ -n "$LAST_REVIEWER_OUTPUT" ]; then
  REVIEWER_SECTION=$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "$LAST_REVIEWER_SEVERITY")
else
  REVIEWER_SECTION="_Reviewer was not invoked because /run-acceptance never reached green._"
fi

ralph_block_issue "$ISSUE_NUM" \
  "max-iterations-exhausted" \
  "$BRANCH" \
  "$RALPH_SESSION_LOG" \
  "$SCENARIOS" \
  "$REVIEWER_SECTION" \
  "$BLOCKED_COMMENT_TEMPLATE"

ralph_end_session "blocked" "max-iterations-reached"
exit 1
