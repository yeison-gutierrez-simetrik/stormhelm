#!/bin/bash
# Ralph local AFK loop — bootstrapped by /setup
#
# Usage:
#   ./templates/ralph-local.sh <issue-number> [max-iterations]
#
# Engine env knobs:
#   RALPH_MODEL           engine model, forwarded as `claude --model` on every
#                         call — run the engine on a cheaper/different tier than
#                         the interactive session; unset = CLI default (FU-83)
#   RALPH_FALLBACK_MODEL  one-shot fallback model when an engine outage is
#                         detected — a different model is a different rate
#                         bucket, so a rate-window collapse recovers in-process
#                         instead of ending the session (FU-83/84)
#   RALPH_ENGINE_MAX      consecutive engine no-ops / zero-progress iterations
#                         tolerated before engine_failure (default 3, FU-74/84)
#   RALPH_ENGINE_BACKOFF  seconds between engine no-op retries (default 60)
#   RALPH_CALL_TIMEOUT    per-call wall-clock cap (s) — a hung engine call (host
#                         sleep / dropped connection) is killed and treated as an
#                         engine outage instead of hanging the run (default 1800,
#                         needs GNU timeout/gtimeout; FU-92)
#
# Reads the GitHub issue, runs /tdd + /run-acceptance until every
# @release scenario passes or the budget is exhausted. Before opening
# the draft PR it invokes the reviewer agent and embeds its report.
#
# Implements: §63 (label gate), §65 (max-iterations), §66 (reviewer
#             pre-PR + retry on blocking), §67 (draft PR),
#             §66 (ralph-blocked label + structured comment via
#                  block_issue + comment template),
#             §69 (NDJSON session log via ralph-lib.sh),
#             §70 (exponential backoff on HTTP 429 via
#                  call_claude_with_retry).
# Status: production-ready (per docs/specs/ralph-hardening.md).

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────
# Bootstrap: locate and source ralph-lib.sh
# ──────────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RALPH_LIB="${SCRIPT_DIR}/ralph-lib.sh"
BLOCKED_COMMENT_TEMPLATE="${SCRIPT_DIR}/ralph-blocked-comment.md.tmpl"

if [ ! -f "$RALPH_LIB" ]; then
  echo "❌ ralph-lib.sh not found in ${SCRIPT_DIR}" >&2
  echo "   Expected: $RALPH_LIB" >&2
  exit 1
fi

if [ ! -f "$BLOCKED_COMMENT_TEMPLATE" ]; then
  echo "❌ ralph-blocked-comment.md.tmpl not found in ${SCRIPT_DIR}" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$RALPH_LIB"

# Reviewer output captured for the "current attempt" — used to enrich
# the ralph-blocked comment when reviewer findings drive the block.
LAST_REVIEWER_OUTPUT=""
LAST_REVIEWER_SEVERITY=""
# FOLLOW-UP 34: the previous iteration's failure_reason — an actionable
# diagnosis the gate already produced — feeds the NEXT /tdd prompt instead
# of forcing the session to re-discover the failure from scratch (or miss
# it). Cleared after a green iteration.
LAST_FAIL_REASON=""

# ──────────────────────────────────────────────────────────────────────
# Argument parsing
#   ./ralph-local.sh <issue> [max-iter]            positional (back-compat)
#   ./ralph-local.sh <issue> --max-iterations N    override the iteration cap
#   ./ralph-local.sh <issue> --worker-id ID        label this worker (parallel runs)
#   ./ralph-local.sh                               QUEUE MODE — work the whole
#                                                  open `ralph-ready` backlog
# The flags match what README + §63/§107 already document; previously the script
# only accepted positionals, so `--max-iterations`/`--worker-id` were silently
# mis-parsed as the issue number.
# ──────────────────────────────────────────────────────────────────────
ISSUE_NUM=""
MAX_ITER=""
WORKER_ID="${RALPH_WORKER_ID:-w0}"
# --base <ref> (FOLLOW-UP 38a): slice-group chaining — branch from <ref>
# instead of the current HEAD and open the PR AGAINST <ref>'s branch.
# Deliberate §123 stacked exception for Night Shift slice-groups (merge-
# commit required; finding-attribution mandatory; see core/13).
BASE_REF=""
PR_BASE_REF=""
RESUMED=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --max-iterations) MAX_ITER="${2:?--max-iterations requires a value}"; shift 2 ;;
    --max-iterations=*) MAX_ITER="${1#*=}"; shift ;;
    --worker-id) WORKER_ID="${2:?--worker-id requires a value}"; shift 2 ;;
    --worker-id=*) WORKER_ID="${1#*=}"; shift ;;
    --base) BASE_REF="${2:?--base requires a ref}"; shift 2 ;;
    --base=*) BASE_REF="${1#*=}"; shift ;;
    # --pr-base (FOLLOW-UP 48): when the queue builds an EPHEMERAL integration
    # base (multi-dep chain), the branch starts from --base (local integration)
    # but the PR must target a REAL remote branch — the chain anchor.
    --pr-base) PR_BASE_REF="${2:?--pr-base requires a ref}"; shift 2 ;;
    --pr-base=*) PR_BASE_REF="${1#*=}"; shift ;;
    # --resumed (FOLLOW-UP 77): ralph-isolated's resume path sets this. The
    # issue was validated on its first launch and Ralph removed `ralph-ready`
    # when it claimed it — bypass ONLY the ralph-ready existence check on
    # re-entry (scenarios/budget/§63 grammar all still run).
    --resumed) RESUMED=1; shift ;;
    --) shift; break ;;
    -*) echo "❌ unknown flag: $1" >&2; exit 2 ;;
    *)
      if [ -z "$ISSUE_NUM" ]; then ISSUE_NUM="$1"
      elif [ -z "$MAX_ITER" ]; then MAX_ITER="$1"
      else echo "❌ unexpected argument: $1" >&2; exit 2; fi
      shift ;;
  esac
done
MAX_ITER="${MAX_ITER:-30}"
export RALPH_WORKER_ID="$WORKER_ID"
BRANCH_PREFIX="agent/feature"

# Queue mode (§63/§107, dependency-aware since FOLLOW-UP 43): no issue →
# drain the whole OPEN `ralph-ready` backlog, foundations first. Each issue
# runs via a self-invocation (per-issue path byte-identical to a single run;
# a blocked issue does not stop the queue). Eligibility comes from the
# `## Depends on` section /to-issues writes into every issue body:
#   - default (merged-deps): runnable ⟺ every dep issue is CLOSED. A
#     dependent whose foundation has a draft PR awaiting review WAITS —
#     that pause IS the require-human-review gate.
#   - RALPH_QUEUE_CHAINED=1 (opt-in): a dep that is OPEN but labeled
#     ralph-done (draft PR delivered) also satisfies — the dependent runs
#     --base <the dep's PR branch> (the §123 Night Shift stacking
#     exception; never a silent default).
# Runnable set is ordered ASC by number (foundations are created first by
# construction); skipped issues are LOUD (stdout + ralph.queue.skipped
# NDJSON); eligibility re-evaluates after every completed item so a
# foundation that delivers mid-night unlocks its dependents (chained mode).
#
# ⚠️ ONE queue worker per repo (FOLLOW-UP 46c): nothing claims an issue
# for a worker — two concurrent queue workers would list the same
# ralph-ready set and double-process it. Parallelism = explicit per-issue
# `ralph-isolated` launches. (A ralph-claimed:<worker> label scheme is the
# designed fix if multi-worker queues are ever needed.)
if [ -z "$ISSUE_NUM" ]; then
  CANDIDATES_JSON=$(gh issue list --label ralph-ready --state open --json number,body --limit 1000 2>/dev/null || echo '[]')
  READY_NUMS=$(printf '%s' "$CANDIDATES_JSON" | jq -r '.[].number' 2>/dev/null | sort -n || true)
  if [ -z "$READY_NUMS" ]; then
    echo "✅ No open 'ralph-ready' issues. Nothing to do."
    exit 0
  fi
  QUEUE_MODE_NAME=$([ -n "${RALPH_QUEUE_CHAINED:-}" ] && echo chained || echo merged-deps)
  echo "🤖 Queue mode (worker ${WORKER_ID}, ${QUEUE_MODE_NAME}): $(echo "$READY_NUMS" | tr '\n' ' ')"

  # Queue-level NDJSON log (the per-issue runs create their own).
  QUEUE_STAMP=$(date -u +%Y%m%d-%H%M%S)
  RALPH_SESSION_ID="ralph-queue-${QUEUE_STAMP}-${WORKER_ID}"
  RALPH_SESSION_LOG=".planning/ralph-sessions/queue-${QUEUE_STAMP}.log"
  mkdir -p .planning/ralph-sessions
  : > "$RALPH_SESSION_LOG"

  # FOLLOW-UP 46a: the night's start snapshot. Every NON-chained item
  # branches from here — never from whatever branch the previous item's
  # child left HEAD on (shared worktree).
  QUEUE_START_REF=$(git rev-parse HEAD)

  queue_deps_of() {  # candidate number → its dep numbers (section-scoped)
    printf '%s' "$CANDIDATES_JSON" \
      | jq -r --argjson n "$1" '.[] | select(.number == $n) | .body // ""' \
      | ralph_deps_from_body
  }
  queue_state_of() {  # issue number → OPEN | CLOSED | MISSING
    printf '%s' "$ALL_JSON" | jq -r --argjson n "$1" 'first(.[] | select(.number == $n) | .state) // "MISSING"'
  }
  queue_dep_done() {  # dep number labeled ralph-done?
    printf '%s' "$ALL_JSON" | jq -e --argjson n "$1" 'any(.[] | select(.number == $n) | .labels[].name; . == "ralph-done")' >/dev/null 2>&1
  }
  queue_base_branch_of() {  # dep number → its open PR's head branch (chained)
    gh pr list --state open --json headRefName,body \
      --jq ".[] | select(.body | contains(\"Closes #${1}\")) | .headRefName" 2>/dev/null | head -1
  }

  PROCESSED=" "
  CONFLICTED=" "
  queue_rc=0
  progress=1
  while [ "$progress" = "1" ]; do
    progress=0
    # Fresh satisfaction snapshot each pass — a foundation that just
    # delivered (ralph-done) or merged must unlock dependents this night.
    ALL_JSON=$(gh issue list --state all --json number,state,labels --limit 1000 2>/dev/null || echo '[]')
    for n in $READY_NUMS; do
      case "$PROCESSED" in *" $n "*) continue ;; esac
      case "$CONFLICTED" in *" $n "*) continue ;; esac
      blocked_on=""
      done_branches=""
      for d in $(queue_deps_of "$n"); do
        [ "$d" = "$n" ] && continue
        st=$(queue_state_of "$d")
        if [ "$st" = "CLOSED" ]; then continue; fi
        if [ "$st" = "MISSING" ]; then
          # FOLLOW-UP 56: a '#N' that is a PULL REQUEST parses as a
          # nonexistent ISSUE — name the real mistake instead of blocking
          # the night with a misleading reason. The grammar: '## Depends
          # on' lists same-repo ISSUES only (PRs are annotated elsewhere;
          # cross-repo deps make the issue shift:hitl — see core/13).
          if gh pr view "$d" >/dev/null 2>&1; then
            echo "⚠️  Issue #$n: Depends-on ref #$d is a PULL REQUEST, not an issue — the section lists same-repo issues only. Treating as blocked." >&2
          else
            echo "⚠️  Issue #$n depends on #$d which does not exist — treating as blocked (fix the Depends-on section)." >&2
          fi
          blocked_on="${blocked_on}${blocked_on:+,}$d"
          continue
        fi
        if [ -n "${RALPH_QUEUE_CHAINED:-}" ] && queue_dep_done "$d"; then
          # ralph-done = draft PR delivered, awaiting human merge → chain on it.
          # FOLLOW-UP 48: collect EVERY delivered dep's branch — picking the
          # first only ran a multi-dep issue on an incomplete base (live: a
          # 3-dep diamond burned 118k tokens rediscovering the missing
          # siblings, and converged byte-identical by luck, not contract).
          b=$(queue_base_branch_of "$d" || true)
          if [ -n "$b" ]; then
            done_branches="${done_branches}${done_branches:+ }$b"
            continue
          fi
          echo "⚠️  Issue #$n: dep #$d is ralph-done but its PR branch could not be discovered — treating as blocked." >&2
        fi
        blocked_on="${blocked_on}${blocked_on:+,}$d"
      done
      if [ -n "$blocked_on" ]; then
        continue   # not runnable this pass; reported after the queue settles
      fi
      # Resolve the chain base from the delivered deps (FOLLOW-UP 48):
      #   0 → independent (start-snapshot path below)
      #   1 → chain directly on it (the FU-43 single-dep path, unchanged)
      #  ≥2 → EPHEMERAL INTEGRATION BASE: merge all dep branches (they share
      #       the foundation by construction); a merge conflict between
      #       siblings is a REAL divergence signal → blocked loudly, never
      #       built on one side. The PR still targets the FIRST dep's branch
      #       (the chain anchor — the integration branch is local-only); its
      #       diff shows sibling code until the merge train advances (§123).
      base_branch=""
      pr_base=""
      if [ -n "$done_branches" ]; then
        set -- $done_branches
        if [ "$#" -eq 1 ]; then
          base_branch="$1"
        else
          INTEGRATION="queue-integration/${n}"
          pr_base="$1"
          git branch -q -D "$INTEGRATION" 2>/dev/null || true
          if git checkout -q -b "$INTEGRATION" "$1" 2>/dev/null; then
            base_branch="$INTEGRATION"
            shift
            for b in "$@"; do
              if ! git merge -q --no-edit "$b" >/dev/null 2>&1; then
                # FOLLOW-UP 61: the engine HAS the forensics right here —
                # name branches and files in the event so the skip is
                # self-service, and print the reconciliation recipe.
                CONFLICT_FILES=$(git diff --name-only --diff-filter=U 2>/dev/null | head -10)
                CF_JSON=$(printf '%s\n' "$CONFLICT_FILES" | grep . | jq -R . | jq -cs . 2>/dev/null || echo '[]')
                DB_JSON=$(printf '%s\n' $done_branches | jq -R . | jq -cs . 2>/dev/null || echo '[]')
                echo "⚠️  Issue #$n: dep branches diverge — 'git merge $b' conflicts on the integration base (files: $(printf '%s' "$CONFLICT_FILES" | tr '\n' ' '))." >&2
                echo "    Reconcile (core/13): merge the ADVANCED dep tip into the diverged sibling (newest into oldest), resolve keeping both sides' intent, push, relaunch issue #$n." >&2
                ralph_log_event "warn" "ralph.queue.skipped" \
                  "{\"issue\":${n},\"reason\":\"dep-branches-conflict\",\"dep_branches\":${DB_JSON},\"conflict_files\":${CF_JSON},\"mode\":\"${QUEUE_MODE_NAME}\"}"
                git merge --abort >/dev/null 2>&1 || true
                git checkout -q --detach "$QUEUE_START_REF" 2>/dev/null || true
                git branch -q -D "$INTEGRATION" 2>/dev/null || true
                base_branch=""
                CONFLICTED="${CONFLICTED}${n} "
                break
              fi
            done
          else
            echo "⚠️  Issue #$n: could not build the integration base from '$1' — treating as blocked." >&2
            CONFLICTED="${CONFLICTED}${n} "
          fi
          case "$CONFLICTED" in *" $n "*) continue ;; esac
        fi
      fi
      echo ""; echo "════════ Issue #$n ${base_branch:+(chained on ${base_branch}) }════════"
      if [ -n "$base_branch" ]; then
        "$0" "$n" --max-iterations "$MAX_ITER" --worker-id "$WORKER_ID" --base "$base_branch" ${pr_base:+--pr-base "$pr_base"} || queue_rc=$?
      else
        # FOLLOW-UP 46a: the previous item's child left HEAD on ITS branch
        # (shared worktree) — an independent item must branch from the
        # night's start snapshot, never from a sibling's tip (the second
        # PR would carry the first's commits). Detach, don't re-fetch:
        # the night is ONE consistent snapshot.
        git checkout -q --detach "$QUEUE_START_REF" 2>/dev/null \
          || echo "⚠️  could not reset to the queue start ref ${QUEUE_START_REF} — issue #$n may branch from the previous item's tip" >&2
        "$0" "$n" --max-iterations "$MAX_ITER" --worker-id "$WORKER_ID" || queue_rc=$?
      fi
      PROCESSED="${PROCESSED}${n} "
      # Housekeeping (consumer-review nit): the ephemeral integration base
      # served its purpose once the child branched from it — its commits
      # stay reachable from the child's branch.
      if [ -n "$pr_base" ]; then
        git branch -q -D "queue-integration/${n}" 2>/dev/null || true
      fi
      progress=1
      break   # re-evaluate eligibility (fresh snapshot) after every item
    done
  done

  # Whatever never became runnable: LOUD per-issue skips (never silent caps),
  # naming the blockers; a mutual pair is called out as a cycle explicitly.
  ALL_JSON=$(gh issue list --state all --json number,state,labels --limit 1000 2>/dev/null || echo '[]')
  for n in $READY_NUMS; do
    case "$PROCESSED" in *" $n "*) continue ;; esac
    blocked_on=""
    for d in $(queue_deps_of "$n"); do
      [ "$d" = "$n" ] && continue
      [ "$(queue_state_of "$d")" = "CLOSED" ] && continue
      blocked_on="${blocked_on}${blocked_on:+,}$d"
      if printf '%s\n' "$READY_NUMS" | grep -qx "$d" && queue_deps_of "$d" | grep -qx "$n"; then
        echo "⚠️  DEPENDENCY CYCLE: #$n ↔ #$d — neither can run; fix the Depends-on sections." >&2
      fi
    done
    case "$CONFLICTED" in
      *" $n "*)
        # FOLLOW-UP 61: the detailed event (branches + files + recipe)
        # was emitted at detection time — only the human recap here.
        echo "⏭  Issue #$n skipped — dep branches CONFLICT on the integration base (see the ralph.queue.skipped event for branches/files + the core/13 recipe)"
        continue ;;
    esac
    echo "⏭  Issue #$n skipped — waiting on: #${blocked_on:-?} (mode: ${QUEUE_MODE_NAME})"
    ralph_log_event "warn" "ralph.queue.skipped" \
      "{\"issue\":${n},\"blocked_on\":[${blocked_on:-}],\"mode\":\"${QUEUE_MODE_NAME}\"}"
  done
  # FOLLOW-UP 46b: terminal queue event — the --queue watcher exits on it
  # (a CHILD's session.ended is not terminal for the night).
  PROCESSED_COUNT=$(echo "$PROCESSED" | wc -w | tr -d ' ')
  TOTAL_COUNT=$(printf '%s\n' "$READY_NUMS" | grep -c .)
  ralph_log_event "info" "ralph.queue.completed" \
    "{\"processed\":${PROCESSED_COUNT},\"skipped\":$((TOTAL_COUNT - PROCESSED_COUNT)),\"rc\":${queue_rc},\"mode\":\"${QUEUE_MODE_NAME}\"}"
  exit "$queue_rc"
fi

# ──────────────────────────────────────────────────────────────────────
# §63 label-contract validation (must run BEFORE init_session so we
# never leave an empty log file for issues we refuse to process).
# One combined fetch: labels (the contract) + title (slug + PR title,
# FOLLOW-UP 36) — the engine used to hit the API twice for one issue.
# ──────────────────────────────────────────────────────────────────────
ISSUE_JSON=$(gh issue view "$ISSUE_NUM" --json labels,title,body 2>/dev/null || true)
LABELS=$(printf '%s' "$ISSUE_JSON" | jq -r '.labels[].name' 2>/dev/null || true)
ISSUE_TITLE=$(printf '%s' "$ISSUE_JSON" | jq -r '.title // empty' 2>/dev/null || true)
ISSUE_BODY=$(printf '%s' "$ISSUE_JSON" | jq -r '.body // empty' 2>/dev/null || true)

if [ -z "$LABELS" ]; then
  echo "❌ Issue #$ISSUE_NUM does not exist or gh CLI is not authenticated" >&2
  exit 1
fi

if [ "${RESUMED:-0}" != "1" ] && ! ralph_has_label "$LABELS" "ralph-ready"; then
  echo "❌ Issue #$ISSUE_NUM is missing label 'ralph-ready' (§63)" >&2
  exit 1
fi
if [ "${RESUMED:-0}" = "1" ] && ! ralph_has_label "$LABELS" "ralph-ready"; then
  echo "🔁 --resumed: bypassing the ralph-ready check (Ralph removed the label when it claimed this issue; the scenarios/budget checks still run) — FOLLOW-UP 77." >&2
fi

# FOLLOW-UP 72: a foundation slice with >9 scenarios OMITS the GH scenarios:
# label (it overflows GitHub's 50-char limit — FU-71) and carries the spelled
# list in the issue body's **Labels:** line instead. The §63 gate must accept
# EITHER source — the GH label OR a scenarios:scn-* token in the body — or
# every such slice is un-launchable (live: belong #83, 19 scns scn-137..155).
if ! echo "$LABELS" | grep -qE "^scenarios:" \
   && ! printf '%s' "$ISSUE_BODY" | grep -qE 'scenarios:scn-[0-9]'; then
  echo "❌ Issue #$ISSUE_NUM declares no scenarios — neither a 'scenarios:scn-*' GitHub label nor a 'scenarios:scn-*' token in the issue body (§63 mandatory). For a >9-scenario slice, carry the spelled list in the body's **Labels:** line (FU-71)." >&2
  exit 1
fi

if ! echo "$LABELS" | grep -qE "^budget:"; then
  echo "❌ Issue #$ISSUE_NUM is missing label 'budget:NNk' (§63 mandatory)" >&2
  exit 1
fi

# Extract labeled metadata
# FOLLOW-UP 72: GH label first (normal slices, unchanged); fall back to the
# body's scenarios:scn-* token when the label was omitted for overflow
# (FU-71). The `|| true` is MANDATORY — ralph_read_label_value's grep|head
# pipeline returns 1 on no-match, and under `set -euo pipefail` a bare
# VAR=$(…) abort is SILENT (the second live failure shape — a run that died
# before any fallback with no message). Same grammar as INV-5's parser.
SCENARIOS=$(ralph_read_label_value "$LABELS" "scenarios:" || true)
if [ -z "$SCENARIOS" ]; then
  SCENARIOS=$(printf '%s' "$ISSUE_BODY" | grep -oE 'scenarios:[a-z0-9+,.-]+' | head -1 | sed 's/^scenarios://' || true)
fi
BUDGET=$(ralph_read_label_value "$LABELS" "budget:" || true)
BUDGET_TOKENS=$(ralph_parse_budget_label "$BUDGET")

# FOLLOW-UP 35: an unsupported label grammar expands to ZERO scenarios with no
# error — downstream that is catastrophic-but-quiet (empty Step-3 selection,
# blind summaries). Fail loudly BEFORE iteration 1, same class as the env
# pre-flight. FU-96: the range form scn-A..scn-B is now a SUPPORTED grammar
# (ralph_expand_scns expands it) — so a >8-scn slice's range label passes here;
# only a genuinely garbage label (expands to nothing) still fails.
if [ -n "$SCENARIOS" ] && [ -z "$(ralph_expand_scns "$SCENARIOS")" ]; then
  echo "❌ Issue #$ISSUE_NUM has an unparseable scenarios label '${SCENARIOS}' — canonical form is scenarios:scn-NNN+NNN or the range scn-A..scn-B (see /to-issues Step 6). Fix the label and relaunch." >&2
  exit 1
fi

# FOLLOW-UP 49 backstop: the GATE runs what the LABEL says, but scope
# amendments are written to the BODY (the FU-17 channel) — live, four
# security scenarios were implemented from a body amendment and shipped
# WITHOUT ever passing acceptance because the scenarios label was never
# rotated (the budget label was — a half-rotation, proving the contract
# was missing, not skipped once). If the body's scenario sections own
# scns the label doesn't, abort BEFORE iteration 1, pre-spend.
# Two capture shapes (the consumer review caught the second): the canonical
# heading sections, AND the legacy blockquote/bold inline form the live
# incident actually used (`> **Scope amendment (date):** … scn-067..070`),
# which closes on a blank line or the next heading.
BODY_SCNS=$(printf '%s' "$ISSUE_BODY" | tr -d '\r' \
  | awk '{ low = tolower($0) }
      low ~ /^#+[ \t]+(scenarios covered|scope amendment)/ { mode = "h"; next }
      low ~ /^>?[ \t]*\**scope amendment/ { mode = "b"; print; next }
      /^#/ { mode = "" }
      mode == "b" && /^[ \t]*$/ { mode = "" }
      mode != "" { print }' \
  | grep -oE 'scn-[0-9]+' | sort -u || true)
if [ -n "$BODY_SCNS" ]; then
  LABEL_SCNS_SORTED=$(ralph_expand_scns "$SCENARIOS" | tr ' ' '\n' | grep . | sort -u || true)
  UNGATED=$(comm -23 <(printf '%s\n' "$BODY_SCNS") <(printf '%s\n' "$LABEL_SCNS_SORTED") | tr '\n' ' ')
  if [ -n "${UNGATED// /}" ]; then
    echo "❌ Issue #$ISSUE_NUM: the body's scenario sections own ${UNGATED}but the scenarios label only covers '${SCENARIOS}' — those scenarios would ship UNGATED. Rotate the label (gh issue edit --remove-label 'scenarios:<old>' --add-label 'scenarios:<new>') or fix the body, then relaunch." >&2
    exit 1
  fi
fi

# ──────────────────────────────────────────────────────────────────────
# Initialize session log (§69) — from here on, every action is recorded
# ──────────────────────────────────────────────────────────────────────
ralph_init_session "$ISSUE_NUM"

ralph_log_event "info" "ralph.contract.validated" \
  "{\"scenarios\":$(ralph_json_string "$SCENARIOS"),\"budget\":$(ralph_json_string "$BUDGET"),\"budget_tokens\":${BUDGET_TOKENS},\"max_iterations\":${MAX_ITER}}"

# ──────────────────────────────────────────────────────────────────────
# Environment pre-flight — fail fast BEFORE iteration 1. An environment
# failure (Docker daemon down, placeholder secrets) fails every iteration
# identically and no code edit can fix it. This is an OPERATOR problem,
# not an issue problem: exit without labeling ralph-blocked so the issue
# stays ralph-ready for the relaunch.
# ──────────────────────────────────────────────────────────────────────
if ! PREFLIGHT_MSG=$(ralph_env_preflight); then
  echo "$PREFLIGHT_MSG" >&2
  ralph_log_event "error" "ralph.preflight.failed" \
    "{\"reason\":$(ralph_json_string "$PREFLIGHT_MSG")}"
  ralph_end_session "blocked" "env-preflight-failed"
  exit 1
fi

# FOLLOW-UP 73: --base is valid for `git checkout -b` (a remote-tracking ref
# like `origin/main` is a fine start point) but `gh pr create --base` needs a
# BRANCH NAME (`main`, not `origin/main`). Without this, a run with
# `--base origin/main` does ALL the work, pushes the branch, then fails at the
# final PR-creation step — the FU-35 arg-expansion class, at the MOST expensive
# point (after the full spend). Validate the PR base up front so it fails
# BEFORE iteration 1. The git start-point keeps the full ref (line below);
# only the gh --base argument is normalized (at PR-create time).
PR_BASE_PROBE="${PR_BASE_REF:-${BASE_REF:-}}"
if [ -n "$PR_BASE_PROBE" ]; then
  PR_BASE_PROBE="${PR_BASE_PROBE#origin/}"
  if git ls-remote --exit-code --heads origin "$PR_BASE_PROBE" >/dev/null 2>&1; then
    :   # the PR base is a real branch on origin
  else
    LSR_RC=$?
    if [ "$LSR_RC" = "2" ]; then
      echo "❌ Issue #$ISSUE_NUM: --base resolves to '$PR_BASE_PROBE', which is not a branch on origin. 'gh pr create --base' needs a BRANCH NAME (e.g. 'main'), never a remote-tracking ref like 'origin/main'. Relaunch with '--base main' (or omit --base for a standalone slice)." >&2
      ralph_end_session "blocked" "pr-base-not-a-branch"
      exit 1
    fi
    # network / other (rc 128, …) → do not block on a transient failure; the
    # gh pr create step is the backstop.
    echo "⚠️  could not verify the PR base '$PR_BASE_PROBE' on origin (ls-remote rc=$LSR_RC) — proceeding; gh pr create is the backstop." >&2
  fi
fi

# ──────────────────────────────────────────────────────────────────────
# Helper: after each successful claude call, check if we've exceeded
# the issue's budget. If yes, block the issue and exit cleanly.
# ──────────────────────────────────────────────────────────────────────
check_budget_or_block() {
  local context_label="${1:-unknown}"
  if ! ralph_check_budget "$BUDGET_TOKENS"; then
    echo "💸 Budget exceeded after ${context_label}: ${RALPH_TOKENS_CUMULATIVE} > ${BUDGET_TOKENS} tokens."
    ralph_log_event "error" "ralph.budget.exceeded" \
      "{\"cumulative\":${RALPH_TOKENS_CUMULATIVE},\"budget\":${BUDGET_TOKENS},\"at_call\":$(ralph_json_string "$context_label")}"
    REVIEWER_SECTION="${LAST_REVIEWER_OUTPUT:+$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "$LAST_REVIEWER_SEVERITY")}"
    REVIEWER_SECTION="${REVIEWER_SECTION:-_Reviewer not invoked before budget exhaustion._}"
    ralph_block_issue "$ISSUE_NUM" \
      "budget-exceeded-during-${context_label}" \
      "$BRANCH" \
      "$RALPH_SESSION_LOG" \
      "$SCENARIOS" \
      "$REVIEWER_SECTION" \
      "$BLOCKED_COMMENT_TEMPLATE"
    ralph_end_session "budget_exceeded" "${context_label}"
    exit 1
  fi
}

# ──────────────────────────────────────────────────────────────────────
# FOLLOW-UP 83/84: one-shot model fallback on a suspected engine outage.
# A model-specific rate window is dodged by a DIFFERENT model's bucket
# (the LiteLLM-router fallback pattern) — far faster than serialize-and-
# wait. Opt-in via RALPH_FALLBACK_MODEL; at most once per session.
# Returns 0 if the switch happened (caller retries), 1 otherwise.
# ──────────────────────────────────────────────────────────────────────
FALLBACK_USED=""
ralph_try_model_fallback() {
  [ -n "${RALPH_FALLBACK_MODEL:-}" ] || return 1
  [ -z "$FALLBACK_USED" ] || return 1
  [ "$RALPH_FALLBACK_MODEL" != "${RALPH_MODEL:-}" ] || return 1
  FALLBACK_USED=1
  export RALPH_MODEL="$RALPH_FALLBACK_MODEL"
  ralph_log_event "warn" "ralph.engine.model_fallback" \
    "{\"model\":$(ralph_json_string "$RALPH_MODEL")}"
  echo "🔁 Engine outage suspected — switching the engine to RALPH_FALLBACK_MODEL=${RALPH_MODEL} and retrying (a different model = a different rate bucket)" >&2
  return 0
}

# ──────────────────────────────────────────────────────────────────────
# FOLLOW-UP 84: iteration-level no-progress detector. The FU-74 guard is
# per-call (exit 0 + 0 tokens); a CLI that exits NON-zero without
# matching the 429 regex (the subscription usage-window message) slips
# past it — /tdd burns the iteration as tdd-failed, /run-acceptance as
# result-file-missing — and the loop spins to max_iterations with FROZEN
# tokens (live: 2× 30-iteration allowances burned in one session, work
# already complete). A real work iteration ALWAYS advances the token
# counter, so: RALPH_ENGINE_MAX consecutive non-green iterations with
# zero token delta = engine outage → try the model fallback once, else
# end engine_failure (NOT ralph-blocked: the work is untainted — same
# distinction OpenHands draws with its stuck detector vs iteration cap).
# ──────────────────────────────────────────────────────────────────────
NOPROGRESS_ITERS=0
check_engine_progress_or_fail() {
  local phase="${1:-unknown}"
  if [ "$RALPH_TOKENS_CUMULATIVE" -gt "$ITER_TOKENS_BEFORE" ]; then
    NOPROGRESS_ITERS=0
    return 0
  fi
  NOPROGRESS_ITERS=$((NOPROGRESS_ITERS + 1))
  echo "⚠️  zero token advance this iteration (${phase}) — ${NOPROGRESS_ITERS}/${RALPH_ENGINE_MAX:-3} before declaring an engine outage" >&2
  if [ "$NOPROGRESS_ITERS" -lt "${RALPH_ENGINE_MAX:-3}" ]; then
    return 0
  fi
  if ralph_try_model_fallback; then
    NOPROGRESS_ITERS=0
    return 0
  fi
  echo "🛑 Engine made no progress for ${NOPROGRESS_ITERS} consecutive iterations (${phase}) — ending engine_failure instead of burning the allowance." >&2
  echo "   The implementation may already be COMPLETE: inspect 'git log ${BRANCH}' before --resume (resume when the limit window resets)." >&2
  ralph_end_session "engine_failure" "no token advance for ${NOPROGRESS_ITERS} consecutive iterations (last: ${phase}) — engine outage, not a work problem; the branch may already carry complete work: check 'git log ${BRANCH}' before --resume"
  exit 1
}

# ──────────────────────────────────────────────────────────────────────
# Branch setup
# ──────────────────────────────────────────────────────────────────────
# Sanitize the issue title into a [a-z0-9-]-only slug: non-ASCII (em-dash,
# accents, emoji) passed straight through before and landed in the git ref
# (e.g. a literal U+2014 in the branch name), breaking naive tooling and the
# documented agent/feature-<slug>-<NNN> greppability. tr -c converts every
# non-safe byte (incl. the newline) to '-', -s collapses runs, and the final
# sed strips edge dashes AFTER head so truncation can't leave a trailing '-'.
# NB: iconv exits non-zero on untransliterable bytes (e.g. emoji on BSD
# iconv) while still emitting the transliterated prefix — '|| true' keeps
# pipefail from killing the script and the partial output is exactly what
# we want (the bad byte just disappears instead of becoming a dash).
SLUG=$(printf '%s' "$ISSUE_TITLE" \
  | tr '[:upper:]' '[:lower:]' \
  | { iconv -f utf-8 -t ascii//TRANSLIT 2>/dev/null || true; } \
  | tr -c 'a-z0-9' '-' | tr -s '-' | head -c 40 | sed 's/^-//; s/-$//')
# iconv missing/failing yields an empty slug — never an empty ref segment.
[ -n "$SLUG" ] || SLUG="issue"
BRANCH="${BRANCH_PREFIX}-${SLUG}-${ISSUE_NUM}"

# FOLLOW-UP 38a: with --base, the slice branches from the PREVIOUS sibling's
# branch (chain), not from the current HEAD. The base must exist.
if [ -n "$BASE_REF" ] && ! git rev-parse --verify "$BASE_REF" >/dev/null 2>&1; then
  echo "❌ --base '$BASE_REF' does not resolve to a ref — chain the slice on an existing sibling branch." >&2
  exit 1
fi
if git checkout -b "$BRANCH" ${BASE_REF:+"$BASE_REF"} 2>/dev/null; then
  ralph_git_action "checkout-new" "success" "git checkout -b $BRANCH ${BASE_REF:-}"
else
  git checkout "$BRANCH"
  ralph_git_action "checkout-existing" "success" "git checkout $BRANCH"
fi

echo "🤖 Ralph starting loop for issue #$ISSUE_NUM on branch $BRANCH"
echo "   Session log: $RALPH_SESSION_LOG"
echo "   Scenarios: $SCENARIOS"
echo "   Budget: $BUDGET, Max iterations: $MAX_ITER"

# ──────────────────────────────────────────────────────────────────────
# Main loop
# ──────────────────────────────────────────────────────────────────────
# Structured acceptance result channel (§66): /run-acceptance MUST write
# this file as its last step; the loop reads it with jq. Grepping the
# session's prose for "exit code: 0" is forbidden — phrasing drift read
# green runs as failures for 8 straight iterations on the first live
# consumer run. Per-issue filename so parallel workers don't race.
ACCEPT_RESULT_FILE=".planning/acceptance/issue-${ISSUE_NUM}-result.json"
# FOLLOW-UP 33: the acceptance session ALSO writes the full reviewer report
# here (its Step 8 runs the §114 reviewer — "the single reviewer invocation
# for the slice"); the loop consumes severity from the result file's
# gates.reviewer and the report from this file, and never invokes
# /code-review itself (measured: ~15k tokens of pure duplication per green
# iteration when it did).
REVIEWER_REPORT_FILE=".planning/acceptance/issue-${ISSUE_NUM}-reviewer.md"
mkdir -p .planning/acceptance

for i in $(seq 1 "$MAX_ITER"); do
  echo ""
  echo "=== Iteration $i of $MAX_ITER ==="

  ralph_iteration_start "tdd"
  ITER_EPOCH=$(date +%s)   # staleness floor for this iteration's result file
  ITER_TOKENS_BEFORE=$RALPH_TOKENS_CUMULATIVE   # FU-84: no-progress baseline

  # NOTE the `|| RC=$?` idiom: under `set -e`, a bare VAR=$(cmd) with a
  # non-zero cmd kills the whole script BEFORE the rc check — the 124
  # rate-limit paths below were unreachable and a CLI failure took the
  # loop down without marking the issue ralph-blocked.
  # The session's prose is intentionally DISCARDED (>/dev/null): since the
  # structured result channel, nothing parses it — only the result file and
  # the NDJSON events are signals. stderr stays on the console for live
  # diagnosis. (Capturing into never-read variables implied the prose
  # mattered — it does not.)
  TDD_RC=0
  # FU-34: hand the gate's own diagnosis to the implementer (truncated —
  # it is a pointer, not a transcript; the full trail is in the NDJSON).
  FAIL_FEEDBACK=""
  if [ -n "$LAST_FAIL_REASON" ]; then
    FAIL_FEEDBACK=" PREVIOUS ITERATION failed acceptance with: ${LAST_FAIL_REASON:0:600}. Address this FIRST, then continue."
  fi
  # FOLLOW-UP 74: a claude call that exits 0 with ZERO tokens is an ENGINE
  # outage, not an iteration outcome (ralph_call_claude_with_retry returns
  # 125). Retry the SAME call after a backoff and, after K consecutive,
  # END the session `engine_failure` WITHOUT consuming the iteration
  # allowance — a resume then knows the WORK is fine, only the engine
  # hiccupped. Knobs RALPH_ENGINE_MAX (3) / RALPH_ENGINE_BACKOFF (60s).
  ENGINE_FAILS=0
  while :; do
    TDD_RC=0
    CALL_START=$(date +%s); CALL_TOKENS_BEFORE=$RALPH_TOKENS_CUMULATIVE
    ralph_call_claude_with_retry "/tdd for issue #$ISSUE_NUM. Read the FULL issue — body AND comments ('gh issue view $ISSUE_NUM' plus 'gh issue view $ISSUE_NUM --comments'; the plan and its amendments may live in comments). If the latest comment carries reviewer findings, fix those FIRST. Then the scn-* scenarios mentioned ($SCENARIOS) — advance one slice.${FAIL_FEEDBACK}" >/dev/null || TDD_RC=$?
    ralph_call_completed "tdd" "$CALL_START" "$CALL_TOKENS_BEFORE"
    if [ "$TDD_RC" -eq 125 ]; then
      ENGINE_FAILS=$((ENGINE_FAILS + 1))
      echo "⚠️  engine no-op (exit 0, 0 tokens) on /tdd — attempt ${ENGINE_FAILS}/${RALPH_ENGINE_MAX:-3} (CLI crash / auth window / transport)" >&2
      if [ "$ENGINE_FAILS" -ge "${RALPH_ENGINE_MAX:-3}" ]; then
        # FU-83/84: a different model = a different rate bucket — try the
        # one-shot fallback before declaring the outage terminal.
        if ralph_try_model_fallback; then
          ENGINE_FAILS=0
          continue
        fi
        ralph_end_session "engine_failure" "claude produced zero tokens on ${ENGINE_FAILS} consecutive calls — engine outage, not a work problem (resume when the limit window resets)"
        exit 1
      fi
      sleep "${RALPH_ENGINE_BACKOFF:-60}"
      continue
    fi
    break
  done
  if [ "$TDD_RC" -ne 0 ]; then
    if [ "$TDD_RC" -eq 124 ]; then
      # Rate-limit exhausted — block the issue and bail out.
      ralph_error_tool "claude" "/tdd hit rate-limit exhaustion"
      ralph_iteration_end "rate-limit-exhausted"
      REVIEWER_SECTION="_Not invoked: API rate-limit exhausted during /tdd._"
      ralph_block_issue "$ISSUE_NUM" \
        "rate-limit-exhausted-during-tdd" \
        "$BRANCH" \
        "$RALPH_SESSION_LOG" \
        "$SCENARIOS" \
        "$REVIEWER_SECTION" \
        "$BLOCKED_COMMENT_TEMPLATE"
      ralph_end_session "rate_limit_exhausted" "tdd-call"
      exit 1
    fi
    ralph_error_tool "claude" "/tdd returned non-zero (code $TDD_RC) in iteration $i"
    ralph_iteration_end "tdd-failed"
    # FU-84: a non-zero exit that dodged the 429 regex (usage-window
    # message) lands here with zero tokens — without this check the loop
    # burns ALL iterations as tdd-failed during an engine outage.
    check_engine_progress_or_fail "tdd-failed"
    continue
  fi

  check_budget_or_block "tdd"

  ACCEPTANCE_RC=0
  # FOLLOW-UP 28: delete the previous result BEFORE the acceptance session.
  # A live retry session decided "nothing changed since the last green run"
  # and skipped the mandatory rewrite — the (correct) staleness check then
  # burned the iteration on result-file-stale. With the pre-delete, a
  # session that skips the write produces result-file-missing: an
  # unambiguous contract violation, never confusable with staleness.
  rm -f "$ACCEPT_RESULT_FILE" "$REVIEWER_REPORT_FILE"
  # FOLLOW-UP 52: the ENGINE runs the invariant gate and injects the result —
  # the reviewer's sandbox refuses node invocations (live: two consecutive
  # slices shipped "I could not run the executable gate" caveats), so the
  # mandate moved from "agent shells out" to "engine injects, agent reads"
  # (the FU-33 structured-contract pattern).
  if [ -f scripts/check-invariants.mjs ]; then
    INVARIANTS_RESULT=$(node scripts/check-invariants.mjs 2>&1 || true)
  else
    INVARIANTS_RESULT="scripts/check-invariants.mjs NOT FOUND — consumer missing the /setup runtime scripts; treat as a blocking finding"
  fi
  CALL_START=$(date +%s); CALL_TOKENS_BEFORE=$RALPH_TOKENS_CUMULATIVE
  ralph_call_claude_with_retry "/run-acceptance for the scn-* of issue #$ISSUE_NUM ($SCENARIOS). MANDATORY contract (skills/run-acceptance, final step): write the machine-readable result to ${ACCEPT_RESULT_FILE} with issue, exit_code, scenarios{}, ran, expected, gates{} (including gates.reviewer = your Step-8 reviewer severity), failure_reason — AND the full reviewer report to ${REVIEWER_REPORT_FILE}. ALWAYS rewrite both files fresh in THIS run — even if nothing changed since a previous green run. Do NOT run a separate code review afterwards: your Step-8 reviewer is the single invocation for this slice. INVARIANT GATE RESULT (engine-run; do NOT attempt to run it yourself — read it): ${INVARIANTS_RESULT}" >/dev/null || ACCEPTANCE_RC=$?
  ralph_call_completed "run-acceptance" "$CALL_START" "$CALL_TOKENS_BEFORE"
  if [ "${ACCEPTANCE_RC:-0}" -eq 125 ]; then
    # FOLLOW-UP 74: a zero-token engine no-op on /run-acceptance is an outage,
    # not a failing gate — end the session engine_failure rather than logging
    # a false acceptance failure and burning the next iteration.
    # FU-83/84: try the one-shot model fallback first; the iteration is
    # retried from /tdd (committed work survives, the prompt re-converges).
    if ralph_try_model_fallback; then
      ralph_iteration_end "engine-noop" "model-fallback"
      continue
    fi
    ralph_end_session "engine_failure" "claude produced zero tokens on /run-acceptance — engine outage (resume when the limit window resets)"
    exit 1
  fi
  if [ "$ACCEPTANCE_RC" -eq 124 ]; then
    ralph_error_tool "claude" "/run-acceptance hit rate-limit exhaustion"
    ralph_iteration_end "rate-limit-exhausted"
    REVIEWER_SECTION="_Not invoked: API rate-limit exhausted during /run-acceptance._"
    ralph_block_issue "$ISSUE_NUM" \
      "rate-limit-exhausted-during-acceptance" \
      "$BRANCH" \
      "$RALPH_SESSION_LOG" \
      "$SCENARIOS" \
      "$REVIEWER_SECTION" \
      "$BLOCKED_COMMENT_TEMPLATE"
    ralph_end_session "rate_limit_exhausted" "run-acceptance-call"
    exit 1
  fi

  check_budget_or_block "run-acceptance"

  # Green signal = the structured result file, validated by jq (§66):
  # exists + valid JSON + fresh (this iteration) + right issue +
  # ran >= expected + exit_code == 0. Never the session's prose.
  if ACCEPT_STATUS=$(ralph_acceptance_result_check "$ACCEPT_RESULT_FILE" "$ISSUE_NUM" "$ITER_EPOCH"); then
    # FOLLOW-UP 88: skill-doc delivery gate — runs FIRST in the green branch.
    # A spec/issue that pins "Skill doc `<name>`" as an FR-deliverable but a
    # slice diff that never touches a **/skills/**/*.md is NOT done, even with
    # every scenario green (no scenario exercises a Markdown file). Failing it
    # HERE (before the §114 reviewer) loops back to /tdd so Ralph writes the
    # doc itself, instead of a human merge-gate BLOCK + round-trip. Fires only
    # when a deliverable is declared (na otherwise — a no-op for most slices).
    if [ -f scripts/check-skill-doc-delivery.mjs ]; then
      SKILL_DOC_DECL=$(mktemp)
      printf '%s' "$ISSUE_BODY" > "$SKILL_DOC_DECL"
      if ! SKILL_DOC_OUT=$(node scripts/check-skill-doc-delivery.mjs "${BASE_REF:-origin/main}" "$SKILL_DOC_DECL" 2>&1); then
        rm -f "$SKILL_DOC_DECL"
        echo "🚧 ${SKILL_DOC_OUT}" >&2
        ralph_log_event "warn" "ralph.gate.skill_doc" \
          "{\"result\":\"fail\",\"detail\":$(ralph_json_string "$SKILL_DOC_OUT")}"
        LAST_FAIL_REASON="skill-doc-undelivered — ${SKILL_DOC_OUT}"   # FU-34: feeds next /tdd
        ralph_iteration_end "skill-doc-undelivered" "$SKILL_DOC_OUT"
        echo "⚠️  Iteration $i: acceptance green but the spec-declared skill doc is undelivered — looping to /tdd." >&2
        ralph_budget_checkpoint "$RALPH_TOKENS_CUMULATIVE" "$BUDGET_TOKENS"
        check_engine_progress_or_fail "skill-doc-undelivered"
        continue
      fi
      rm -f "$SKILL_DOC_DECL"
      ralph_log_event "info" "ralph.gate.skill_doc" "{\"result\":\"pass-or-na\"}"
    fi

    ralph_iteration_end "green"
    LAST_FAIL_REASON=""   # FU-34: the diagnosis was consumed; don't leak it forward

    # Per-scenario truth from the result file's scenarios{} map
    # (NOT blanket-passing every labeled scenario).
    ralph_log_scenarios_from_result "$ACCEPT_RESULT_FILE" "$SCENARIOS"

    # ──────────────────────────────────────────────────────────────
    # §66 — Reviewer verdict BEFORE opening PR (FOLLOW-UP 33).
    # The §114 reviewer already ran ONCE inside /run-acceptance (its
    # Step 8: "the single reviewer invocation for the slice"); the
    # session wrote the severity to gates.reviewer and the full report
    # to $REVIEWER_REPORT_FILE. The loop READS both — re-invoking
    # /code-review here duplicated ~15k tokens per green iteration and
    # was the last prose-parsing surface.
    # Retry policy (unchanged):
    #   blocking  → one extra /tdd iteration (counts toward MAX_ITER)
    #   should-fix → embed report, open PR, human decides
    #   suggestion → embed report, open PR
    #   clean      → open PR with brief reviewer-ok note
    # ──────────────────────────────────────────────────────────────
    REVIEWER_SEVERITY=$(jq -r '.gates.reviewer // empty' "$ACCEPT_RESULT_FILE" 2>/dev/null)
    if [ -n "$REVIEWER_SEVERITY" ]; then
      REVIEWER_OUTPUT=$(cat "$REVIEWER_REPORT_FILE" 2>/dev/null \
        || echo "_reviewer report file missing (${REVIEWER_REPORT_FILE}); severity from result file: ${REVIEWER_SEVERITY}_")
      ralph_log_event "info" "ralph.reviewer.findings" \
        "{\"severity\":$(ralph_json_string "$REVIEWER_SEVERITY"),\"source\":\"result-file\"}"
    else
      # Legacy fallback: the result file predates the gates.reviewer
      # contract — invoke the reviewer ONCE here (new-contract sessions
      # never reach this branch).
      echo "🧐 Result file carries no reviewer verdict — fallback /code-review invocation…"
      ralph_log_event "warn" "ralph.reviewer.fallback_invocation" "{\"iteration\":${i}}"
      CALL_START=$(date +%s); CALL_TOKENS_BEFORE=$RALPH_TOKENS_CUMULATIVE
      REVIEWER_OUTPUT=$(ralph_call_claude_with_retry "/code-review on the current diff. Cite the §N rules violated. Mark each finding with 🛑 / ⚠️ / 💡 by severity. MANDATORY: end your report with the literal line 'VERDICT: CLEAN' or 'VERDICT: SUGGESTION' or 'VERDICT: SHOULD-FIX' or 'VERDICT: BLOCKING' — automation parses that exact line." 2>&1 || true)
      ralph_call_completed "code-review" "$CALL_START" "$CALL_TOKENS_BEFORE"
      check_budget_or_block "code-review"
      REVIEWER_SEVERITY=$(ralph_reviewer_severity "$REVIEWER_OUTPUT")
      ralph_log_event "info" "ralph.reviewer.findings" \
        "{\"severity\":$(ralph_json_string "$REVIEWER_SEVERITY"),\"source\":\"fallback-invocation\"}"
    fi
    LAST_REVIEWER_OUTPUT="$REVIEWER_OUTPUT"
    LAST_REVIEWER_SEVERITY="$REVIEWER_SEVERITY"

    if [ "$REVIEWER_SEVERITY" = "blocking" ] && [ "$i" -lt "$MAX_ITER" ]; then
      echo "🛑 Reviewer reported blocking findings. Attempting one extra /tdd iteration to fix…"
      # FOLLOW-UP 26: persist the findings to the channel the implementer
      # READS (FU-17's contract: issue body + comments). Without this the
      # retry /tdd re-ran the standard prompt with NO way to know what to
      # fix (the findings lived only in this shell's memory): the live
      # retry committed nothing, and the findings were unrecoverable after
      # the session died. The comment fixes both — the retry sees them,
      # and they survive any crash for the morning review.
      RETRY_COMMENT=$(printf '## Reviewer findings (iteration %s) — fix these; the acceptance gate re-runs next iteration\n\n%s' \
        "$i" "$(ralph_format_reviewer_section "$REVIEWER_OUTPUT" "$REVIEWER_SEVERITY")")
      if ! gh issue comment "$ISSUE_NUM" --body "$RETRY_COMMENT" >/dev/null 2>&1; then
        ralph_error_tool "gh" "failed to post reviewer findings comment before retry"
      fi
      ralph_log_event "warn" "ralph.reviewer.retry" \
        "{\"reason\":\"blocking-findings\",\"retry_iteration\":$((i+1)),\"findings_posted\":true}"
      # Loop back to the top of the for-loop body for one more iteration.
      # The retry counts toward MAX_ITER because the for-loop increment is implicit.
      continue
    fi

    if [ "$REVIEWER_SEVERITY" = "blocking" ]; then
      # Out of budget for retries — apply ralph-blocked with reviewer context.
      echo "🛑 Reviewer findings still blocking and budget exhausted. Blocking issue."
      ralph_log_event "error" "ralph.reviewer.blocked_no_retry_budget" \
        "{\"iterations_used\":${i},\"max_iterations\":${MAX_ITER}}"
      REVIEWER_SECTION=$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "$LAST_REVIEWER_SEVERITY")
      ralph_block_issue "$ISSUE_NUM" \
        "reviewer-blocking-after-retry-budget-exhausted" \
        "$BRANCH" \
        "$RALPH_SESSION_LOG" \
        "$SCENARIOS" \
        "$REVIEWER_SECTION" \
        "$BLOCKED_COMMENT_TEMPLATE"
      ralph_end_session "blocked" "reviewer-blocking-no-retry-budget"
      exit 1
    fi

    echo "✅ Reviewer severity: ${REVIEWER_SEVERITY}. Creating PR…"

    REVIEWER_SECTION=$(ralph_format_reviewer_section "$REVIEWER_OUTPUT" "$REVIEWER_SEVERITY")

    # FOLLOW-UP 36: review-grade PR, composed from data the engine already
    # holds — both live PRs were manually retitled/re-bodied by the Day
    # Shift before this. Title = the issue's own title; body = per-scenario
    # outcomes (from the result file via summarize), counts, tokens,
    # reviewer verdict + report. Consumers can tune the heredoc.
    PR_TITLE=$(printf '%.110s' "${ISSUE_TITLE:-fix issue} (#${ISSUE_NUM})")
    RAN_EXPECTED=$(jq -r '"\(.ran // "?")/\(.expected // "?")"' "$ACCEPT_RESULT_FILE" 2>/dev/null || echo "?/?")
    SCENARIO_TABLE=$(ralph_summarize_scenarios "$RALPH_SESSION_LOG" "$SCENARIOS")
    # FOLLOW-UP 38a: a chained slice's PR states the stack contract — base
    # merges FIRST and with a MERGE COMMIT (squash breaks stacked diffs).
    STACK_NOTE=""
    if [ -n "$BASE_REF" ]; then
      STACK_NOTE="> 🔗 **STACKED PR (slice-group chain, §123 Night Shift exception):** based on \`${PR_BASE_REF:-$BASE_REF}\` — merge that PR first, and use a **merge commit** (squash breaks the stacked diffs). If the base changes after review, refresh this branch with \`git merge ${PR_BASE_REF:-$BASE_REF}\` and re-gate.${PR_BASE_REF:+ Built on an ephemeral multi-dep integration base — the diff shows sibling code until the merge train advances.}"
    fi

    PR_BODY=$(cat <<EOF
Automated by Ralph. Closes #$ISSUE_NUM
${STACK_NOTE}

**Iterations consumed:** $i / $MAX_ITER
**Scenarios (ran/expected):** $RAN_EXPECTED
$SCENARIO_TABLE

**Tokens consumed:** ${RALPH_TOKENS_CUMULATIVE} / ${BUDGET_TOKENS}
**Reviewer severity:** ${REVIEWER_SEVERITY}
**Session log:** \`$RALPH_SESSION_LOG\`

---

$REVIEWER_SECTION

---

> ⚠️ This PR is in draft state per §67. Merge requires human approval.
EOF
)

    # Push BEFORE creating the PR: non-interactive `gh pr create` aborts on
    # an unpushed branch ("you must first push the current branch…"). This
    # is the first instruction every successful run reaches — and it had
    # never executed until the issue-15 run, where it failed at the finish
    # line. --head makes the call worktree/detached-HEAD-proof.
    if ! git push -u origin "$BRANCH"; then
      ralph_git_action "push" "failed" "git push -u origin $BRANCH"
      ralph_error_tool "git" "git push failed before PR creation"
      REVIEWER_SECTION=$(ralph_format_reviewer_section "$REVIEWER_OUTPUT" "$REVIEWER_SEVERITY")
      ralph_block_issue "$ISSUE_NUM" \
        "git-push-failed" \
        "$BRANCH" \
        "$RALPH_SESSION_LOG" \
        "$SCENARIOS" \
        "$REVIEWER_SECTION" \
        "$BLOCKED_COMMENT_TEMPLATE"
      ralph_end_session "blocked" "git-push-failed"
      exit 1
    fi
    ralph_git_action "push" "success" "git push -u origin $BRANCH"

    # FOLLOW-UP 55 (advisory, never blocking): duplication is the Quality-
    # Gate class local lint structurally cannot see (cross-file, diff-
    # relative). Warn BEFORE the PR exists so the extract-the-clone fix
    # happens in-loop instead of post-PR (+1 CI cycle each time). npx -y
    # keeps the zero-deps convention; any failure is swallowed — a missing
    # npx or offline run must never block a green slice.
    CHANGED_PROD=$(git diff --name-only "${BASE_REF:-origin/main}"...HEAD -- 'src/**' 2>/dev/null | grep -v __tests__ || true)
    if [ -n "$CHANGED_PROD" ] && command -v npx >/dev/null 2>&1; then
      DUP_OUT=$(npx -y jscpd --min-tokens 70 $CHANGED_PROD 2>/dev/null || true)
      if printf '%s' "$DUP_OUT" | grep -qiE "clones? found|duplicated lines.*[1-9]"; then
        echo "⚠️  ADVISORY: duplication detected in this slice's changed files — Sonar's QG will likely flag it post-PR. Extract the clone (never the threshold); locator output:" >&2
        printf '%s
' "$DUP_OUT" | grep -iE "clone|duplicat" | head -5 >&2
        ralph_log_event "warn" "ralph.duplication.warned" "{\"files\":$(printf '%s' "$CHANGED_PROD" | grep -c . || echo 0)}"
      fi
    fi
    PR_TARGET="${PR_BASE_REF:-$BASE_REF}"
    PR_TARGET="${PR_TARGET#origin/}"   # FOLLOW-UP 73: gh --base wants a branch name, not origin/<branch>
    # FOLLOW-UP 64: a SINGLE-issue run (no --base) with declared deps used
    # to open against main — the diff and Sonar's new-code period spanned
    # every unmerged dep (live: a PR showed 4 issues' work and its QG
    # failed on duplication already fixed on a DEP branch). Resolve:
    #   exactly one dep with an open PR  → its branch is the base (the
    #     chain-tail case; deps are created foundations-first, so with >1
    #     we take the HIGHEST-numbered dep whose deps include the others —
    #     a linear chain — otherwise it is a true multi-root);
    #   multi-root / nothing resolvable → keep main, but say so in the PR
    #     body (an honest stacked diff beats a silent one).
    STACKED_DIFF_NOTE=""
    if [ -z "$PR_TARGET" ]; then
      SINGLE_DEPS=$(printf '%s' "$ISSUE_BODY" | ralph_deps_from_body | tr '\n' ' ' || true)
      if [ -n "${SINGLE_DEPS// /}" ]; then
        OPEN_DEP_LIST=""
        for d in $SINGLE_DEPS; do
          b=$(gh pr list --state open --json headRefName,body \
            --jq ".[] | select(.body | contains(\"Closes #${d}\")) | .headRefName" 2>/dev/null | head -1)
          [ -n "$b" ] && OPEN_DEP_LIST="${OPEN_DEP_LIST}${OPEN_DEP_LIST:+ }${d}:${b}"
        done
        DEP_COUNT=$(printf '%s\n' $OPEN_DEP_LIST | grep -c . || true)
        if [ "$DEP_COUNT" = "1" ]; then
          PR_TARGET="${OPEN_DEP_LIST#*:}"
          STACKED_DIFF_NOTE="> 🔗 **STACKED PR (FOLLOW-UP 64):** based on \`${PR_TARGET}\` — this issue's declared dependency. Merge that PR first; merge commit only (§123)."
        elif [ "$DEP_COUNT" -gt 1 ]; then
          # Chain check: the highest-numbered open dep must itself depend on
          # every other open dep (linear chain) for its branch to contain
          # the full stack. Otherwise: true multi-root → honest note.
          LAST_DEP=$(printf '%s\n' $OPEN_DEP_LIST | sed 's/:.*//' | sort -n | tail -1)
          LAST_BRANCH=$(printf '%s\n' $OPEN_DEP_LIST | grep "^${LAST_DEP}:" | head -1 | cut -d: -f2-)
          LAST_DEP_DEPS=$(gh issue view "$LAST_DEP" --json body --jq .body 2>/dev/null | ralph_deps_from_body | tr '\n' ' ' || true)
          CHAIN=1
          for d in $(printf '%s\n' $OPEN_DEP_LIST | sed 's/:.*//'); do
            [ "$d" = "$LAST_DEP" ] && continue
            case " $LAST_DEP_DEPS " in *" $d "*) : ;; *) CHAIN=0 ;; esac
          done
          if [ "$CHAIN" = "1" ]; then
            PR_TARGET="$LAST_BRANCH"
            STACKED_DIFF_NOTE="> 🔗 **STACKED PR (FOLLOW-UP 64):** based on \`${PR_TARGET}\` — the chain tail of this issue's declared dependencies. Merge the chain in order; merge commits only (§123)."
          else
            STACKED_DIFF_NOTE="> ⚠️ **STACKED DIFF (FOLLOW-UP 64):** this PR's base is \`main\` but its diff spans unmerged dependencies ($(printf '%s\n' $OPEN_DEP_LIST | sed 's/:.*//' | sed 's/^/#/' | tr '\n' ' ' | sed 's/ $//')) — review this issue's commits only; analyzer new-code metrics may attribute dep-branch findings here until the deps merge."
          fi
        fi
      fi
    fi
    PR_BASE_ARGS=()
    [ -n "$PR_TARGET" ] && PR_BASE_ARGS=(--base "$PR_TARGET")
    if gh pr create --draft ${PR_BASE_ARGS[@]+"${PR_BASE_ARGS[@]}"} --head "$BRANCH" --title "$PR_TITLE" --body "$PR_BODY${STACKED_DIFF_NOTE:+

$STACKED_DIFF_NOTE}"; then
      ralph_git_action "pr-create" "success" "gh pr create --draft"
      # FOLLOW-UP 41: provision ralph-done just-in-time (mirror of the block
      # path's ralph-blocked). Re-sync-adopted consumers never re-run /setup,
      # and gh fails the rotation SILENTLY when the label doesn't exist —
      # the first live autonomous run ended with ZERO ralph-* labels on the
      # issue (lost ralph-ready, gained nothing).
      gh label create "ralph-done" --force --color "5319E7" \
        --description "Ralph delivered a draft PR for this issue" >/dev/null 2>&1 || true
      if ! gh issue edit "$ISSUE_NUM" --add-label ralph-done --remove-label ralph-ready >/dev/null 2>&1; then
        ralph_error_tool "gh" "label rotation (ralph-ready → ralph-done) failed for issue #$ISSUE_NUM"
      fi
      ralph_log_event "info" "ralph.pr.opened" \
        "{\"severity\":$(ralph_json_string "$REVIEWER_SEVERITY")}"
      ralph_end_session "completed"
      exit 0
    else
      ralph_git_action "pr-create" "failed" "gh pr create --draft"
      ralph_error_tool "gh" "gh pr create returned non-zero"
      ralph_end_session "blocked" "gh-pr-create-failed"
      exit 1
    fi
  fi

  # Not green — ACCEPT_STATUS carries the machine-greppable reason
  # (result-file-missing / -stale / exit_code=N: <failure_reason> / …),
  # so a failing run is diagnosable from the NDJSON alone. Per-scenario
  # events are fed only when the file is fresh and for THIS issue (a
  # stale or foreign file must not pollute the scenario summary).
  case "$ACCEPT_STATUS" in
    exit_code=*|ran-below-expected*)
      ralph_log_scenarios_from_result "$ACCEPT_RESULT_FILE" "$SCENARIOS"
      # FOLLOW-UP 33: per the skill, a BLOCKING reviewer verdict makes the
      # acceptance exit non-zero — so blocking normally arrives HERE, not
      # on the green path. Surface the full report through FU-26's channel
      # (issue comment) so the next iteration's /tdd sees what to fix.
      FAIL_REVIEWER=$(jq -r '.gates.reviewer // empty' "$ACCEPT_RESULT_FILE" 2>/dev/null)
      if [ "$FAIL_REVIEWER" = "blocking" ] && [ -f "$REVIEWER_REPORT_FILE" ]; then
        LAST_REVIEWER_OUTPUT=$(cat "$REVIEWER_REPORT_FILE")
        LAST_REVIEWER_SEVERITY="blocking"
        BLOCKING_COMMENT=$(printf '## Reviewer findings (iteration %s) — fix these; the acceptance gate re-runs next iteration\n\n%s' \
          "$i" "$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "blocking")")
        if ! gh issue comment "$ISSUE_NUM" --body "$BLOCKING_COMMENT" >/dev/null 2>&1; then
          ralph_error_tool "gh" "failed to post reviewer findings comment on failing iteration"
        fi
        ralph_log_event "info" "ralph.reviewer.findings" \
          "{\"severity\":\"blocking\",\"source\":\"result-file\",\"posted_to_issue\":true}"
      fi ;;
  esac
  LAST_FAIL_REASON="$ACCEPT_STATUS"   # FU-34: feeds the next /tdd prompt
  ralph_iteration_end "acceptance-failing" "$ACCEPT_STATUS"
  echo "⚠️  Iteration $i did not reach green (${ACCEPT_STATUS}). Tokens: ${RALPH_TOKENS_CUMULATIVE}/${BUDGET_TOKENS}. Continuing…"
  ralph_budget_checkpoint "$RALPH_TOKENS_CUMULATIVE" "$BUDGET_TOKENS"
  # FU-84: result-file-missing with FROZEN tokens is the rate-window loop
  # (live: 30× "did not reach green (result-file-missing)" at a frozen
  # counter, twice in one session). A genuinely failing-but-working
  # iteration always advances tokens and resets the counter.
  check_engine_progress_or_fail "$ACCEPT_STATUS"
done

echo "❌ Ralph exhausted $MAX_ITER iterations without green. Marking issue as ralph-blocked."

# Use the reviewer section from the last attempt if any, otherwise a placeholder.
if [ -n "$LAST_REVIEWER_OUTPUT" ]; then
  REVIEWER_SECTION=$(ralph_format_reviewer_section "$LAST_REVIEWER_OUTPUT" "$LAST_REVIEWER_SEVERITY")
else
  REVIEWER_SECTION="_Reviewer was not invoked because /run-acceptance never reached green._"
fi

ralph_block_issue "$ISSUE_NUM" \
  "max-iterations-exhausted" \
  "$BRANCH" \
  "$RALPH_SESSION_LOG" \
  "$SCENARIOS" \
  "$REVIEWER_SECTION" \
  "$BLOCKED_COMMENT_TEMPLATE"

ralph_end_session "blocked" "max-iterations-reached"
exit 1
