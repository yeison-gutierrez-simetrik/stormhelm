#!/usr/bin/env bash
# ralph-local.sh — Canonical template for Stormhelm's Night Shift loop.
#
# Generated by /setup at project init; customizable per project but the
# control flow is fixed by core/13-ralph-and-afk.md (§63-§70, §107, §114).
#
# Requirements: gh CLI authenticated, claude CLI, jq, Docker (sandbox).
#
# Usage:
#   caffeinate -i ./ralph-local.sh > .planning/ralph-tonight.log 2>&1 &   # macOS
#   systemd-inhibit ./ralph-local.sh > .planning/ralph-tonight.log 2>&1 & # Linux

set -euo pipefail

# === Configuration (substituted by /setup based on stack) ===
LABEL="ralph-ready"
MAX_ITERATIONS_PER_ISSUE=30
SANDBOX_IMAGE="claude-sandbox:latest"
TEST_CMD="${TEST_CMD:-npm test}"
ACCEPTANCE_CMD="${ACCEPTANCE_CMD:-npm run test:acceptance}"
LINT_CMD="${LINT_CMD:-npm run lint}"
TYPECHECK_CMD="${TYPECHECK_CMD:-npm run typecheck}"
LOG_DIR=".planning/ralph-sessions"
BUDGET_FILE=".planning/budget.txt"

mkdir -p "$LOG_DIR"

# === Helpers ===
log() {
  echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $*"
}

current_budget() {
  cat "$BUDGET_FILE" 2>/dev/null || echo "0"
}

extract_budget_from_label() {
  # extract NNk from "budget:NNk" label and convert to integer tokens
  local issue_labels="$1"
  local budget_label
  budget_label=$(echo "$issue_labels" | grep -oP 'budget:\K[0-9]+k' || echo "50k")
  echo "${budget_label%k}000"
}

extract_scenarios_from_labels() {
  local issue_labels="$1"
  echo "$issue_labels" | grep -oP 'scn-\d+' | tr '\n' ',' | sed 's/,$//'
}

# === Main loop ===
log "Ralph starting. Budget remaining: $(current_budget) tokens."

while :; do
  # === §63: filter to ralph-ready issues with scn-NNN labels ===
  ISSUE_JSON=$(gh issue list \
    --label "$LABEL" \
    --state open \
    --limit 1 \
    --json number,title,body,labels,url 2>/dev/null || echo "[]")

  ISSUE_NUMBER=$(echo "$ISSUE_JSON" | jq -r '.[0].number // empty')

  if [ -z "$ISSUE_NUMBER" ]; then
    log "No issues '$LABEL' remaining. Ralph done."
    break
  fi

  ISSUE_LABELS=$(echo "$ISSUE_JSON" | jq -r '.[0].labels[].name' | tr '\n' ' ')
  ISSUE_TITLE=$(echo "$ISSUE_JSON" | jq -r '.[0].title')

  # §63 enforcement: require at least one scn-NNN label
  SCENARIOS=$(extract_scenarios_from_labels "$ISSUE_LABELS")
  if [ -z "$SCENARIOS" ]; then
    log "Issue #$ISSUE_NUMBER has no scenarios:scn-* label. Aborting per §63."
    gh issue edit "$ISSUE_NUMBER" --remove-label "$LABEL" --add-label "ralph-blocked"
    gh issue comment "$ISSUE_NUMBER" --body "Aborted by Ralph: no \`scenarios:scn-*\` label. See §63."
    continue
  fi

  # === §63 + §65: budget check ===
  ESTIMATED=$(extract_budget_from_label "$ISSUE_LABELS")
  CURRENT=$(current_budget)
  if [ "$ESTIMATED" -gt "$CURRENT" ]; then
    log "Issue #$ISSUE_NUMBER needs $ESTIMATED tokens, only $CURRENT remaining. Skipping."
    gh issue edit "$ISSUE_NUMBER" --remove-label "$LABEL" --add-label "budget-exceeded"
    continue
  fi

  # === §75: brownfield branch prefix ===
  if echo "$ISSUE_LABELS" | grep -q "shift:hybrid\|brownfield"; then
    BRANCH="agent/legacy/issue-$ISSUE_NUMBER"
  else
    BRANCH="agent/issue-$ISSUE_NUMBER"
  fi

  log "Working on issue #$ISSUE_NUMBER ('$ISSUE_TITLE') on branch $BRANCH (scenarios: $SCENARIOS)"

  # === Setup branch ===
  git checkout main
  git pull --ff-only
  git checkout -b "$BRANCH" 2>/dev/null || git checkout "$BRANCH"

  # === §66 + §65: invoke /tdd with iteration cap ===
  SESSION_LOG="$LOG_DIR/issue-$ISSUE_NUMBER-$(date +%Y%m%d-%H%M%S).log"

  # The actual claude invocation runs the /tdd skill against the issue.
  # In production this passes through the sandbox; here is the minimal form.
  docker run --rm \
    -v "$(pwd):/workspace" \
    -w /workspace \
    -e ANTHROPIC_API_KEY \
    -e CLAUDE_PROJECT_DIR=/workspace \
    "$SANDBOX_IMAGE" \
    claude -p \
      --max-iterations "$MAX_ITERATIONS_PER_ISSUE" \
      --system-prompt "$(cat docs/engineering/AGENTS.md)" \
      "Invoke /tdd for issue #$ISSUE_NUMBER. Plan is in the issue body. Scenarios to satisfy: $SCENARIOS." \
      2>&1 | tee "$SESSION_LOG"

  TDD_EXIT=${PIPESTATUS[0]}

  if [ "$TDD_EXIT" -ne 0 ]; then
    log "Issue #$ISSUE_NUMBER: /tdd exited non-zero. Marking ralph-blocked per §66."
    gh issue edit "$ISSUE_NUMBER" --remove-label "$LABEL" --add-label "ralph-blocked"
    gh issue comment "$ISSUE_NUMBER" --body "Ralph: /tdd failed. Session log: \`$SESSION_LOG\`. See §66."
    continue
  fi

  # === Run /run-acceptance gate ===
  # /run-acceptance internally invokes the reviewer agent (§114) at Step 8.
  # If reviewer finds 🛑, /run-acceptance exits non-zero and we get one retry per §66.
  if ! claude -p \
      --max-iterations 1 \
      "Invoke /run-acceptance for issue #$ISSUE_NUMBER. Scenarios: $SCENARIOS." \
      >> "$SESSION_LOG" 2>&1; then

    log "Issue #$ISSUE_NUMBER: /run-acceptance failed. Retrying once per §66."

    if ! claude -p \
        --max-iterations "$MAX_ITERATIONS_PER_ISSUE" \
        "Address blocking findings from previous /run-acceptance for issue #$ISSUE_NUMBER and re-run." \
        >> "$SESSION_LOG" 2>&1; then

      log "Issue #$ISSUE_NUMBER: still failing after retry. Marking ralph-blocked."
      gh issue edit "$ISSUE_NUMBER" --remove-label "$LABEL" --add-label "ralph-blocked"
      gh issue comment "$ISSUE_NUMBER" --body "Ralph: /run-acceptance failed after retry. Session: \`$SESSION_LOG\`."
      continue
    fi
  fi

  # === §67: open draft PR ===
  PR_BODY=$(cat <<EOF
Closes #$ISSUE_NUMBER

Generated by Ralph local. Session log: \`$SESSION_LOG\`.
Reviewer report attached from /run-acceptance Step 8.
Scenarios satisfied: $SCENARIOS.

🤖 Generated with [Claude Code](https://claude.com/claude-code)
EOF
)

  gh pr create \
    --draft \
    --base main \
    --head "$BRANCH" \
    --title "Closes #$ISSUE_NUMBER: $ISSUE_TITLE" \
    --body "$PR_BODY"

  gh issue edit "$ISSUE_NUMBER" --remove-label "$LABEL" --add-label "ralph-done"

  # === Update budget ===
  CONSUMED=$(grep -oP 'tokens_total:\s*\K\d+' "$SESSION_LOG" | tail -1 || echo "$ESTIMATED")
  NEW_BUDGET=$((CURRENT - CONSUMED))
  echo "$NEW_BUDGET" > "$BUDGET_FILE"

  log "Issue #$ISSUE_NUMBER done. Budget remaining: $NEW_BUDGET tokens."
done

# === Final notification (macOS / Linux) ===
MSG="Ralph finished. Budget remaining: $(current_budget) tokens. Review draft PRs in the morning."
osascript -e "display notification \"$MSG\" with title \"Stormhelm\"" 2>/dev/null || \
  notify-send "Stormhelm" "$MSG" 2>/dev/null || \
  log "$MSG"
