#!/usr/bin/env bash
# Mock `gh` for the Ralph loop test (scripts/__tests__/ralph-loop.test.mjs).
# Deterministic; env-driven. Covers only the subcommands ralph-local.sh uses.
#   MOCK_LABELS  newline-separated labels for `issue view --json labels` (default: a valid contract)
#   MOCK_TITLE   title for `issue view --json title`
#   MOCK_READY   newline-separated issue numbers for `issue list` (queue mode)
sub="$1 $2"
case "$sub" in
  "issue view")
    if printf '%s\n' "$@" | grep -q labels; then
      if [ -n "${MOCK_LABELS+x}" ]; then printf '%s\n' "$MOCK_LABELS"
      else printf 'ralph-ready\nscenarios:scn-001\nbudget:50k\n'; fi
    elif printf '%s\n' "$@" | grep -q title; then
      printf '%s\n' "${MOCK_TITLE:-Feature X}"
    fi ;;
  "issue list") printf '%s\n' "${MOCK_READY:-1}" ;;
  "pr list")
    # Pre-formatted rows (the real call uses --jq); empty by default so the
    # watcher's empty-list path (FOLLOW-UP 32 lesson 3) is exercised.
    if [ -n "${MOCK_PR_LIST:-}" ]; then printf '%s\n' "$MOCK_PR_LIST"; fi ;;
  "pr create")
    # Real gh contract (FOLLOW-UP 29): creating a PR for a branch that was
    # never pushed aborts. The sentinel is written by the mock git's `push`.
    if [ -f .mock-pushed ]; then
      # Record full args (title/body) for FU-33/FU-36 assertions.
      printf '%s\n―――\n' "$*" >> .mock-gh-prcreate
      echo "https://github.com/acme/app/pull/9"
    else
      echo "aborted: you must first push the current branch to a remote, or use the --head flag" >&2
      exit 1
    fi ;;
  "issue comment")
    # Record posted comments so tests can assert on them (FOLLOW-UP 26).
    printf '%s\n―――\n' "$*" >> .mock-gh-comments ;;
  "label create")
    # Record label provisioning so tests can assert on it (FOLLOW-UP 30a).
    printf '%s\n' "$*" >> .mock-gh-labels ;;
  "issue edit") : ;;
  *) : ;;
esac
exit 0
