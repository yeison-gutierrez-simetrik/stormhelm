#!/usr/bin/env bash
# Mock `gh` for the Ralph loop test (scripts/__tests__/ralph-loop.test.mjs).
# Deterministic; env-driven. Covers only the subcommands ralph-local.sh uses.
#   MOCK_LABELS  newline-separated labels for `issue view --json labels` (default: a valid contract)
#   MOCK_TITLE   title for `issue view --json title`
#   MOCK_READY   newline-separated issue numbers for `issue list` (queue mode)
sub="$1 $2"
case "$sub" in
  "issue view")
    labels="${MOCK_LABELS-ralph-ready
scenarios:scn-001
budget:50k}"
    if printf '%s\n' "$@" | grep -q "labels,title"; then
      # Combined fetch (FOLLOW-UP 36): real JSON, parsed client-side with jq.
      jq -n --arg l "$labels" --arg t "${MOCK_TITLE:-Feature X}" \
        '{labels: ($l | split("\n") | map(select(length > 0) | {name: .})), title: $t}'
    elif printf '%s\n' "$@" | grep -q labels; then
      printf '%s\n' "$labels"
    elif printf '%s\n' "$@" | grep -q title; then
      printf '%s\n' "${MOCK_TITLE:-Feature X}"
    fi ;;
  "issue list")
    # FOLLOW-UP 43 (dependency-aware queue): two JSON variants —
    #   --json number,body          → MOCK_QUEUE_JSON (candidates with Depends-on
    #                                 bodies; default: MOCK_READY numbers, empty bodies)
    #   --json number,state,labels  → MOCK_ALL_JSON (satisfaction snapshot; default [])
    # Legacy plain form keeps emitting MOCK_READY lines.
    if printf '%s\n' "$@" | grep -q "number,body"; then
      if [ -n "${MOCK_QUEUE_JSON:-}" ]; then printf '%s\n' "$MOCK_QUEUE_JSON"
      else jq -n --arg r "${MOCK_READY:-1}" '[ $r | split("\n")[] | select(length > 0) | {number: (. | tonumber), body: ""} ]'; fi
    elif printf '%s\n' "$@" | grep -q "number,state,labels"; then
      printf '%s\n' "${MOCK_ALL_JSON:-[]}"
    else
      printf '%s\n' "${MOCK_READY:-1}"
    fi ;;
  "pr list")
    # Pre-formatted rows (the real call uses --jq); empty by default so the
    # watcher's empty-list path (FOLLOW-UP 32 lesson 3) is exercised.
    # FOLLOW-UP 48: per-dep branch discovery — when the --jq carries a
    # "Closes #N" filter and MOCK_PR_BRANCH_<N> is set, answer per dep
    # (a multi-dep chain needs DIFFERENT branches per dependency).
    dep=$(printf '%s\n' "$@" | grep -oE 'Closes #[0-9]+' | grep -oE '[0-9]+' | head -1)
    if [ -n "$dep" ] && eval "[ -n \"\${MOCK_PR_BRANCH_${dep}:-}\" ]"; then
      eval "printf '%s\n' \"\$MOCK_PR_BRANCH_${dep}\""
    elif [ -n "${MOCK_PR_LIST:-}" ]; then printf '%s\n' "$MOCK_PR_LIST"; fi ;;
  "pr create")
    # Real gh contract (FOLLOW-UP 29): creating a PR for a branch that was
    # never pushed aborts. The sentinel is written by the mock git's `push`.
    if [ -f .mock-pushed ]; then
      # Record full args (title/body) for FU-33/FU-36 assertions.
      printf '%s\n―――\n' "$*" >> .mock-gh-prcreate
      echo "https://github.com/acme/app/pull/9"
    else
      echo "aborted: you must first push the current branch to a remote, or use the --head flag" >&2
      exit 1
    fi ;;
  "issue comment")
    # Record posted comments so tests can assert on them (FOLLOW-UP 26).
    printf '%s\n―――\n' "$*" >> .mock-gh-comments ;;
  "label create")
    # Record label provisioning so tests can assert on it (FOLLOW-UP 30a).
    printf '%s\n' "$*" >> .mock-gh-labels ;;
  "issue edit")
    # FOLLOW-UP 41: real gh REFUSES --add-label for a label that doesn't
    # exist in the repo (and the engine used to swallow that failure
    # silently). Enforce here: every added label must have been
    # `label create`d first — pins the live failure mode so the JIT
    # provisioning can't regress silently.
    prev=""
    for a in "$@"; do
      if [ "$prev" = "--add-label" ]; then
        for lbl in $(printf '%s' "$a" | tr ',' ' '); do
          if ! grep -q -- "$lbl" .mock-gh-labels 2>/dev/null; then
            echo "failed to update: '$lbl' not found" >&2
            exit 1
          fi
        done
      fi
      prev="$a"
    done ;;
  *) : ;;
esac
exit 0
