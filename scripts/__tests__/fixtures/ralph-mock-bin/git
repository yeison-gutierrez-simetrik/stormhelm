#!/usr/bin/env bash
# Mock `git` for the Ralph loop test (FOLLOW-UP 29). Intercepts ONLY `push`
# — records the pushed state in a sentinel file so the mock `gh` can enforce
# the real CLI's contract (`pr create` aborts on an unpushed branch). Every
# other subcommand passes through to the real git.
#   MOCK_PUSH_FAIL  if set, `git push` fails (network/permission simulation)
if [ "${1:-}" = "push" ]; then
  if [ -n "${MOCK_PUSH_FAIL:-}" ]; then
    echo "mock git: push rejected (MOCK_PUSH_FAIL)" >&2
    exit 1
  fi
  touch .mock-pushed
  exit 0
fi
# FOLLOW-UP 73: intercept `git ls-remote --heads origin <branch>` (the PR-base
# pre-flight). Default: the branch EXISTS (exit 0) so existing tests that pass
# a --base are unaffected. MOCK_LSREMOTE_HEADS (space-separated) restricts the
# set of branches that "exist"; a queried branch not in it → exit 2 (no match),
# exactly what the real git returns and what the pre-flight aborts on.
if [ "${1:-}" = "ls-remote" ]; then
  if [ -z "${MOCK_LSREMOTE_HEADS:-}" ]; then exit 0; fi
  q="${@: -1}"   # last arg = the queried branch name
  for b in $MOCK_LSREMOTE_HEADS; do
    if [ "$b" = "$q" ]; then printf '%s\trefs/heads/%s\n' "deadbeef" "$q"; exit 0; fi
  done
  exit 2
fi
# Resolve the REAL git by scanning PATH while excluding this mock's own
# directory — `command -v -p` proved unreliable (it can return this very
# script → infinite exec recursion → the whole suite hangs).
SELF_DIR=$(cd "$(dirname "$0")" && pwd)
if [ -x /usr/bin/git ] && [ "$(cd /usr/bin && pwd)" != "$SELF_DIR" ]; then
  exec /usr/bin/git "$@"
fi
IFS=':' read -ra _DIRS <<< "$PATH"
for d in "${_DIRS[@]}"; do
  [ -z "$d" ] && continue
  [ "$(cd "$d" 2>/dev/null && pwd)" = "$SELF_DIR" ] && continue
  if [ -x "$d/git" ]; then
    exec "$d/git" "$@"
  fi
done
echo "mock git: real git not found on PATH" >&2
exit 127
