#!/usr/bin/env bash
# Mock `claude` for the Ralph loop test. `claude -p "<prompt>"` — prompt follows -p.
#   MOCK_ACCEPT           legacy knob: anything other than "exit code: 0" → failing result
#   MOCK_REVIEW           reviewer report text (written to the issue-<N>-reviewer.md file
#                         by the acceptance branch; also stdout for /code-review fallback)
#   MOCK_ACCEPT_REVIEWER  gates.reviewer severity the acceptance session reports
#                         (default clean; "blocking" → exit_code 1 per the skill's Step 11)
#   MOCK_GREEN_WITH_BLOCKING  contract-violation case: exit_code 0 + gates.reviewer blocking
#   MOCK_NO_REVIEWER_GATE legacy contract: omit gates.reviewer + the reviewer file
#   MOCK_FAIL_ISSUE       if set, /run-acceptance for that issue # writes a FAILING result file
#   MOCK_NO_RESULT_FILE   if set, /run-acceptance does NOT write the result file
#   MOCK_IN_TOKENS / MOCK_OUT_TOKENS  usage reported per call in JSON mode (default 1200/340)
#
# Every prompt is appended to .mock-claude-prompts so tests can assert WHAT the
# loop asked for (FU-33: zero /code-review on green; FU-34: failure feedback).
#
# Since FOLLOW-UP 14 the loop's green signal is the structured result file; since
# FOLLOW-UP 33 the reviewer verdict/report arrive via gates.reviewer + the
# issue-<N>-reviewer.md file (the acceptance session's embedded Step-8 reviewer).
json_mode=""
prompt=""; prev=""
for a in "$@"; do
  [ "$prev" = "--output-format" ] && [ "$a" = "json" ] && json_mode=1
  [ "$prev" = "-p" ] && prompt="$a"
  prev="$a"
done
printf '%s\n―――\n' "$prompt" >> .mock-claude-prompts
# emit <text> — honors --output-format json with a result envelope + usage,
# mirroring the real CLI (text mode carries no usage data at all).
emit() {
  if [ -n "$json_mode" ]; then
    printf '{"type":"result","subtype":"success","result":"%s","usage":{"input_tokens":%s,"output_tokens":%s}}\n' \
      "$1" "${MOCK_IN_TOKENS:-1200}" "${MOCK_OUT_TOKENS:-340}"
  else
    printf '%s\n' "$1"
  fi
}
if echo "$prompt" | grep -q "/tdd"; then
  # MOCK_TDD_COMMIT: simulate the session committing work (FU-46a drift test —
  # without a real commit per issue, branch-base pollution is undetectable).
  if [ -n "${MOCK_TDD_COMMIT:-}" ]; then
    issue=$(echo "$prompt" | grep -oE '#[0-9]+' | head -1 | tr -d '#')
    echo "work" >> "work-issue-${issue}.txt"
    git add -A >/dev/null 2>&1
    git -c user.email=ralph@mock -c user.name=ralph-mock commit -qm "tdd work for issue ${issue}" >/dev/null 2>&1 || true
  fi
  emit "advanced one slice; unit tests green"; exit 0
fi
if echo "$prompt" | grep -q "/run-acceptance"; then
  issue=$(echo "$prompt" | grep -oE '#[0-9]+' | head -1 | tr -d '#')
  green=1
  if [ -n "${MOCK_FAIL_ISSUE:-}" ] && [ "$issue" = "${MOCK_FAIL_ISSUE}" ]; then green=0; fi
  if [ -n "${MOCK_ACCEPT:-}" ] && [ "${MOCK_ACCEPT}" != "exit code: 0" ]; then green=0; fi
  # MOCK_FAIL_FIRST: fail only the FIRST acceptance run (fail→green arcs, FU-34)
  if [ -n "${MOCK_FAIL_FIRST:-}" ] && [ ! -f .mock-acc-ran ]; then green=0; fi
  touch .mock-acc-ran
  reviewer="${MOCK_ACCEPT_REVIEWER:-clean}"
  if [ -z "${MOCK_NO_RESULT_FILE:-}" ]; then
    mkdir -p .planning/acceptance
    # The embedded Step-8 reviewer report (always written, pass or fail),
    # unless the legacy-contract knob is on.
    if [ -z "${MOCK_NO_REVIEWER_GATE:-}" ]; then
      printf 'MOCK-REVIEWER-REPORT\n%s\n' "${MOCK_REVIEW:-Reviewed diff. No findings. VERDICT: CLEAN}" \
        > ".planning/acceptance/issue-${issue}-reviewer.md"
      gates_extra=", \"reviewer\": \"${reviewer}\""
      report_field=", \"reviewer_report\": \".planning/acceptance/issue-${issue}-reviewer.md\""
    else
      gates_extra=""
      report_field=""
    fi
    if [ "$green" = "1" ] && [ "$reviewer" = "blocking" ] && [ -z "${MOCK_GREEN_WITH_BLOCKING:-}" ]; then
      # Skill Step 11: a 🛑 reviewer verdict makes the gate exit non-zero.
      printf '{ "issue": %s, "exit_code": 1, "scenarios": { "scn-001": "passed" }, "ran": 1, "expected": 1, "gates": { "smoke": "pass", "slice_scenarios": "pass"%s }%s, "failure_reason": "gates green but reviewer verdict BLOCKING" }\n' \
        "$issue" "$gates_extra" "$report_field" > ".planning/acceptance/issue-${issue}-result.json"
    elif [ "$green" = "1" ]; then
      printf '{ "issue": %s, "exit_code": 0, "scenarios": { "scn-001": "passed" }, "ran": 1, "expected": 1, "gates": { "smoke": "pass", "slice_scenarios": "pass"%s }%s, "failure_reason": null }\n' \
        "$issue" "$gates_extra" "$report_field" > ".planning/acceptance/issue-${issue}-result.json"
    else
      printf '{ "issue": %s, "exit_code": 1, "scenarios": { "scn-001": "failed: step assertion" }, "ran": 1, "expected": 1, "gates": { "smoke": "fail"%s }%s, "failure_reason": "mock forced failure" }\n' \
        "$issue" "$gates_extra" "$report_field" > ".planning/acceptance/issue-${issue}-result.json"
    fi
  fi
  if [ "$green" = "1" ]; then emit "ran scenarios. all gates green"; else emit "ran scenarios. smoke gate failed"; fi
  exit 0
fi
if echo "$prompt" | grep -q "/code-review"; then emit "${MOCK_REVIEW:-Reviewed diff. No blocking issues. 💡 minor: extract a helper.}"; exit 0; fi
emit "ok"; exit 0
